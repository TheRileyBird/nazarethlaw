---
import '../styles/global.css';
import Button from '../components/Button.astro';
import { Image } from 'astro:assets';
import { Menu, X, Phone, Mail } from '@lucide/astro';
import logoHorizontal from '../assets/images/logo-horizontal.png';
import logo from '../assets/images/logo.png';

interface Props {
  title: string;
  description: string;
  heroImage?: any;
}

const { title, description, heroImage } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Nazareth Law Firm</title>
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <!-- Navigation -->
    <nav x-data="{ mobileMenuOpen: false }" class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-20">
          <a href="/" class="flex-shrink-0 drop-shadow-md hover:drop-shadow-lg transition-all duration-300">
            <Image src={logoHorizontal} alt="Nazareth Law Firm" class="h-12 w-auto" />
          </a>

          <div class="hidden md:flex items-center space-x-8" >
            <a href="/#practice-areas" class="text-gray-700 hover:text-primary-600 font-medium transition-colors">Practice Areas</a>
            <a href="/#about" class="text-gray-700 hover:text-primary-600 font-medium transition-colors">About</a>
            <a href="/#contact" class="text-gray-700 hover:text-primary-600 font-medium transition-colors">Contact</a>
            <Button href="tel:+15044082284" variant="secondary" size="md">
              <Phone class="w-4 h-4" />
              504-408-2284
            </Button>
          </div>

          <button @click="mobileMenuOpen = !mobileMenuOpen" class="md:hidden p-2 rounded-lg hover:bg-gray-100 transition-colors">
            <Menu x-show="!mobileMenuOpen" class="w-6 h-6 text-gray-700" />
            <X x-show="mobileMenuOpen" x-cloak class="w-6 h-6 text-gray-700" />
          </button>
        </div>

        <div x-show="mobileMenuOpen" x-cloak class="md:hidden py-4 border-t border-gray-100">
          <div class="flex flex-col space-y-3">
            <a href="/#practice-areas" class="text-gray-700 hover:text-primary-600 font-medium px-3 py-2 hover:bg-gray-50 transition-colors">Practice Areas</a>
            <a href="/#about" class="text-gray-700 hover:text-primary-600 font-medium px-3 py-2 hover:bg-gray-50 transition-colors">About</a>
            <a href="/#contact" class="text-gray-700 hover:text-primary-600 font-medium px-3 py-2 hover:bg-gray-50 transition-colors">Contact</a>
            <Button href="tel:+15044082284" variant="secondary" size="md" class="w-full">
              <Phone class="w-4 h-4" />
              504-408-2284
            </Button>
          </div>
        </div>
      </div>
    </nav>

    <!-- Hero Section -->
    <section class="relative h-96 flex items-center justify-center overflow-hidden pt-20">
      {heroImage && (
        <div class="absolute inset-0">
          <Image
            src={heroImage}
            alt={title}
            class="w-full h-full object-cover object-center"
            loading="eager"
          />
          <div class="absolute inset-0 bg-gradient-to-br from-accent-900/90 via-accent-800/85 to-accent-700/80"></div>
        </div>
      )}
      {!heroImage && (
        <div class="absolute inset-0 bg-gradient-to-br from-accent-900 via-accent-800 to-accent-700"></div>
      )}

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="inline-block mb-6" x-data x-intersect="$el.classList.add('animate')">
          <div class="h-1 w-24 bg-gradient-to-r from-primary-400 via-primary-300 to-transparent"></div>
        </div>
        <h1 class="text-white mb-6 stagger-1" x-data x-intersect="$el.classList.add('animate')">
          {title}
        </h1>
        <p class="text-xl sm:text-2xl text-white/90 max-w-3xl mx-auto leading-relaxed stagger-2" x-data x-intersect="$el.classList.add('animate')">
          {description}
        </p>
      </div>
    </section>

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-accent-500 text-white py-20 border-t-4 border-primary-500">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-3 gap-16 mb-12">
          <div>
            <Image src={logo} alt="Nazareth Law Firm" class="h-24 w-auto mb-6 brightness-0 invert" />
            <p class="text-white/70 leading-relaxed text-base">
              Expert legal representation for victims of major industrial disasters and environmental exposures.
            </p>
          </div>

          <div>
            <h3 class="text-sm font-bold mb-6 text-white uppercase tracking-widest">Quick Links</h3>
            <ul class="space-y-3">
              <li><a href="/#practice-areas" class="text-white/70 hover:text-primary-400 transition-colors duration-300 text-base">Practice Areas</a></li>
              <li><a href="/#about" class="text-white/70 hover:text-primary-400 transition-colors duration-300 text-base">About</a></li>
              <li><a href="/#contact" class="text-white/70 hover:text-primary-400 transition-colors duration-300 text-base">Contact</a></li>
            </ul>
          </div>

          <div>
            <h3 class="text-sm font-bold mb-6 text-white uppercase tracking-widest">Contact</h3>
            <ul class="space-y-4 text-white/70">
              <li class="flex items-start gap-3">
                <Phone class="w-5 h-5 mt-1 flex-shrink-0 text-primary-400" />
                <a href="tel:+15044082284" class="hover:text-primary-400 transition-colors duration-300 text-base">504-408-2284</a>
              </li>
              <li class="flex items-start gap-3">
                <Mail class="w-5 h-5 mt-1 flex-shrink-0 text-primary-400" />
                <span class="text-base">info@nazarethlawfirm.com</span>
              </li>
            </ul>
          </div>
        </div>

        <div class="border-t border-white/10 pt-10">
          <div class="flex flex-col sm:flex-row justify-between items-center gap-4 text-white/50">
            <p class="text-sm">&copy; {new Date().getFullYear()} Nazareth Law Firm. All rights reserved.</p>
            <div class="flex gap-8">
              <a href="#" class="hover:text-primary-400 transition-colors duration-300 text-sm">Privacy Policy</a>
              <a href="#" class="hover:text-primary-400 transition-colors duration-300 text-sm">Terms of Service</a>
            </div>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
