---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Nazareth Law Firm | Major Industrial Disaster Attorneys",
  description = "Expert legal representation for victims of major industrial incidents and environmental exposures. Over $50 million secured for individual cases."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body>
    <slot />
  </body>
</html>
