---
import { Image } from 'astro:assets';
import { Menu, X, Phone, ChevronDown } from '@lucide/astro';
import logoHorizontal from '../assets/images/logo-horizontal.png';
---

<!-- Navigation -->
<nav x-data="{ mobileMenuOpen: false, scrolled: false, practiceAreasOpen: false, init() { this.scrolled = window.scrollY > 50; } }" @scroll.window.throttle.50ms="scrolled = window.scrollY > 50" class="fixed top-0 left-0 right-0 z-50 backdrop-blur-sm transition-all duration-500 ease-in-out border-b" :class="scrolled ? 'bg-white/95 border-gray-100 shadow-md' : 'bg-transparent border-transparent'">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between transition-all duration-500 ease-in-out" :class="scrolled ? 'h-16' : 'h-20'">
      <!-- Logo -->
      <a href="/" class="flex-shrink-0 transition-all duration-500 ease-in-out drop-shadow-md hover:drop-shadow-lg">
        <Image src={logoHorizontal} alt="Nazareth Law Firm" class="w-auto transition-all duration-500 ease-in-out" :class="scrolled ? 'h-8' : 'h-12'" />
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center space-x-8">
        <!-- Practice Areas Dropdown -->
        <div class="relative" @mouseenter="practiceAreasOpen = true" @mouseleave="practiceAreasOpen = false">
          <a href="/practice-areas" class="font-bold transition-colors duration-200 text-sm uppercase tracking-wider flex items-center gap-1" :class="scrolled ? 'text-gray-700 hover:text-primary-600' : 'text-white hover:text-primary-300'">
            Practice Areas
            <ChevronDown class="w-4 h-4" />
          </a>
          <div x-show="practiceAreasOpen" x-cloak x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 translate-y-1" x-transition:enter-end="opacity-100 translate-y-0" x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100 translate-y-0" x-transition:leave-end="opacity-0 translate-y-1" class="absolute left-0 mt-2 w-64 bg-white rounded-none shadow-xl border border-gray-200 py-2">
            <a href="/practice-areas/asbestos-mesothelioma" class="block px-4 py-2 text-sm text-gray-700 hover:bg-primary-50 hover:text-primary-600 transition-colors">Asbestos / Mesothelioma</a>
            <a href="/practice-areas/maritime" class="block px-4 py-2 text-sm text-gray-700 hover:bg-primary-50 hover:text-primary-600 transition-colors">Maritime Law</a>
            <a href="/practice-areas/personal-injury" class="block px-4 py-2 text-sm text-gray-700 hover:bg-primary-50 hover:text-primary-600 transition-colors">Personal Injury</a>
            <a href="/practice-areas/premises-liability" class="block px-4 py-2 text-sm text-gray-700 hover:bg-primary-50 hover:text-primary-600 transition-colors">Premises Liability</a>
            <a href="/practice-areas/product-liability" class="block px-4 py-2 text-sm text-gray-700 hover:bg-primary-50 hover:text-primary-600 transition-colors">Product Liability</a>
            <a href="/practice-areas/hurricane-claims" class="block px-4 py-2 text-sm text-gray-700 hover:bg-primary-50 hover:text-primary-600 transition-colors">Hurricane Claims</a>
            <a href="/practice-areas/property-damage" class="block px-4 py-2 text-sm text-gray-700 hover:bg-primary-50 hover:text-primary-600 transition-colors">Property Damage</a>
            <a href="/practice-areas/business-interruption-claims" class="block px-4 py-2 text-sm text-gray-700 hover:bg-primary-50 hover:text-primary-600 transition-colors">Business Interruption</a>
          </div>
        </div>
        <a href="/about" class="font-bold transition-colors duration-200 text-sm uppercase tracking-wider" :class="scrolled ? 'text-gray-700 hover:text-primary-600' : 'text-white hover:text-primary-300'">About</a>
        <a href="/faq" class="font-bold transition-colors duration-200 text-sm uppercase tracking-wider" :class="scrolled ? 'text-gray-700 hover:text-primary-600' : 'text-white hover:text-primary-300'">FAQ</a>
        <a href="/blog" class="font-bold transition-colors duration-200 text-sm uppercase tracking-wider" :class="scrolled ? 'text-gray-700 hover:text-primary-600' : 'text-white hover:text-primary-300'">Blog</a>
        <a href="/contact" class="font-bold transition-colors duration-200 text-sm uppercase tracking-wider" :class="scrolled ? 'text-gray-700 hover:text-primary-600' : 'text-white hover:text-primary-300'">Contact</a>
        <a href="tel:+15044082284" class="inline-flex items-center gap-2 rounded-none font-semibold bg-primary-500 text-white hover:bg-primary-600 shadow-lg hover:shadow-xl shadow-primary-500/20 hover:shadow-primary-500/30 border-2 border-primary-400 transition-all duration-500 ease-in-out" :class="scrolled ? 'px-4 py-2 text-sm' : 'px-6 py-3 text-base'">
          <Phone class="transition-all duration-500 ease-in-out" :class="scrolled ? 'w-3 h-3' : 'w-4 h-4'" />
          504-408-2284
        </a>
      </div>

      <!-- Mobile menu button -->
      <button @click="mobileMenuOpen = !mobileMenuOpen" class="md:hidden p-2 rounded-lg transition-colors" :class="scrolled ? 'hover:bg-gray-100' : 'hover:bg-white/10'">
        <Menu x-show="!mobileMenuOpen" class="w-6 h-6 transition-colors" :class="scrolled ? 'text-gray-700' : 'text-white'" />
        <X x-show="mobileMenuOpen" x-cloak class="w-6 h-6 transition-colors" :class="scrolled ? 'text-gray-700' : 'text-white'" />
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div x-show="mobileMenuOpen" x-cloak class="md:hidden py-4 border-t bg-white/95 backdrop-blur-sm" :class="scrolled ? 'border-gray-100' : 'border-transparent'">
      <div class="flex flex-col space-y-3">
        <a href="/practice-areas" class="text-gray-700 hover:text-primary-600 font-bold px-3 py-2 hover:bg-gray-50 transition-colors uppercase tracking-wider text-sm border-b border-gray-200">All Practice Areas</a>
        <a href="/practice-areas/asbestos-mesothelioma" class="text-gray-700 hover:text-primary-600 font-medium px-3 py-2 hover:bg-gray-50 transition-colors uppercase tracking-wider text-sm">Asbestos / Mesothelioma</a>
        <a href="/practice-areas/maritime" class="text-gray-700 hover:text-primary-600 font-medium px-3 py-2 hover:bg-gray-50 transition-colors uppercase tracking-wider text-sm">Maritime Law</a>
        <a href="/practice-areas/personal-injury" class="text-gray-700 hover:text-primary-600 font-medium px-3 py-2 hover:bg-gray-50 transition-colors uppercase tracking-wider text-sm">Personal Injury</a>
        <a href="/practice-areas/premises-liability" class="text-gray-700 hover:text-primary-600 font-medium px-3 py-2 hover:bg-gray-50 transition-colors uppercase tracking-wider text-sm">Premises Liability</a>
        <a href="/practice-areas/product-liability" class="text-gray-700 hover:text-primary-600 font-medium px-3 py-2 hover:bg-gray-50 transition-colors uppercase tracking-wider text-sm">Product Liability</a>
        <a href="/practice-areas/hurricane-claims" class="text-gray-700 hover:text-primary-600 font-medium px-3 py-2 hover:bg-gray-50 transition-colors uppercase tracking-wider text-sm">Hurricane Claims</a>
        <a href="/practice-areas/property-damage" class="text-gray-700 hover:text-primary-600 font-medium px-3 py-2 hover:bg-gray-50 transition-colors uppercase tracking-wider text-sm">Property Damage</a>
        <a href="/practice-areas/business-interruption-claims" class="text-gray-700 hover:text-primary-600 font-medium px-3 py-2 hover:bg-gray-50 transition-colors uppercase tracking-wider text-sm">Business Interruption</a>
        <a href="/about" class="text-gray-700 hover:text-primary-600 font-medium px-3 py-2 hover:bg-gray-50 transition-colors uppercase tracking-wider text-sm">About</a>
        <a href="/faq" class="text-gray-700 hover:text-primary-600 font-medium px-3 py-2 hover:bg-gray-50 transition-colors uppercase tracking-wider text-sm">FAQ</a>
        <a href="/blog" class="text-gray-700 hover:text-primary-600 font-medium px-3 py-2 hover:bg-gray-50 transition-colors uppercase tracking-wider text-sm">Blog</a>
        <a href="/contact" class="text-gray-700 hover:text-primary-600 font-medium px-3 py-2 hover:bg-gray-50 transition-colors uppercase tracking-wider text-sm">Contact</a>
        <a href="tel:+15044082284" class="inline-flex items-center justify-center gap-2 bg-accent-500 text-white px-6 py-3 rounded-none font-semibold hover:bg-accent-600 transition-colors border-2 border-accent-400">
          <Phone class="w-4 h-4" />
          504-408-2284
        </a>
      </div>
    </div>
  </div>
</nav>
