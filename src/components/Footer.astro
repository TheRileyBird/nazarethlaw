---
import { Image } from 'astro:assets';
import { Phone, Mail, MapPin } from 'lucide-astro';
import lightLogoSquare from '../assets/images/icon.png';
---

<style>
  @keyframes gradientShift {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  .footer-gradient {
    background: linear-gradient(135deg,
      #030712 0%,
      #0a0e1a 25%,
      #030712 50%,
      #0a0e1a 75%,
      #030712 100%
    );
    background-size: 200% 200%;
    animation: gradientShift 20s ease infinite;
  }
</style>

<!-- Footer -->
<footer class="footer-gradient text-white py-20 border-t-4 border-secondary-500 relative overflow-hidden">
  <!-- Subtle pattern overlay -->
  <div class="absolute inset-0 bg-pattern-diagonal opacity-5"></div>

  <!-- Gradient/Glow Background Effects -->
  <div class="absolute top-0 left-0 w-[800px] h-[800px] bg-secondary-500/15 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
  <div class="absolute bottom-0 right-0 w-[900px] h-[900px] bg-primary-500/10 rounded-full blur-3xl translate-x-1/2 translate-y-1/2"></div>
  <div class="absolute top-1/2 right-1/4 w-[600px] h-[600px] bg-secondary-400/8 rounded-full blur-3xl"></div>

  <!-- Large ghosted logo background -->
  <div class="hidden lg:block absolute top-0 right-10 w-auto h-[500px] opacity-[0.09] pointer-events-none">
    <Image src={lightLogoSquare} alt="" class="w-full h-full overflow-hidden" />
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
      <!-- Logo & About -->
      <div class="md:col-span-1">
        <Image src={lightLogoSquare} alt="Nazareth Law Firm" class="w-64 md:w-32 h-auto mb-6 mx-auto md:mx-0" />
        <p class="text-white/80 leading-relaxed text-base text-center md:text-left max-w-96 mx-auto md:mx-0">
          Expert legal representation for victims of major industrial disasters and environmental exposures.
        </p>
      </div>

      <!-- Practice Areas -->
      <div class="hidden lg:block md:col-span-2">
        <div class="grid sm:grid-cols-2 gap-4">
          <a href="/practice-areas/asbestos-mesothelioma" class="text-white/80 hover:text-secondary-400 transition-colors duration-300 text-lg font-medium">Asbestos / Mesothelioma</a>
          <a href="/practice-areas/maritime" class="text-white/80 hover:text-secondary-400 transition-colors duration-300 text-lg font-medium">Maritime Law</a>
          <a href="/practice-areas/personal-injury" class="text-white/80 hover:text-secondary-400 transition-colors duration-300 text-lg font-medium">Personal Injury</a>
          <a href="/practice-areas/premises-liability" class="text-white/80 hover:text-secondary-400 transition-colors duration-300 text-lg font-medium">Premises Liability</a>
          <a href="/practice-areas/product-liability" class="text-white/80 hover:text-secondary-400 transition-colors duration-300 text-lg font-medium">Product Liability</a>
          <a href="/practice-areas/hurricane-claims" class="text-white/80 hover:text-secondary-400 transition-colors duration-300 text-lg font-medium">Hurricane Claims</a>
          <a href="/practice-areas/property-damage" class="text-white/80 hover:text-secondary-400 transition-colors duration-300 text-lg font-medium">Property Damage</a>
          <a href="/practice-areas/business-interruption-claims" class="text-white/80 hover:text-secondary-400 transition-colors duration-300 text-lg font-medium">Business Interruption</a>
        </div>
      </div>

      <!-- Office -->
      <div class="md:col-span-1 mx-auto md:mx-unset">
        <!--<h3 class="text-base font-bold mb-6 text-white uppercase tracking-widest">Office</h3>-->
        <ul class="space-y-4 text-white/70">
          <li class="flex items-start gap-3">
            <MapPin class="w-5 h-5 mt-0.5 flex-shrink-0 text-secondary-400" />
            <div class="text-base">
              650 Poydras Street, Suite 2828<br />
              New Orleans, LA 70130
            </div>
          </li>
          <li class="flex items-start gap-3">
            <Phone class="w-5 h-5 mt-0.5 flex-shrink-0 text-secondary-400" />
            <a href="tel:+15044082284" class="hover:text-secondary-400 transition-colors duration-300 text-base">504-408-2284</a>
          </li>
          <li class="flex items-start gap-3">
            <Mail class="w-5 h-5 mt-0.5 flex-shrink-0 text-secondary-400" />
            <a href="mailto:neil@nazarethlawfirm.com" class="hover:text-secondary-400 transition-colors duration-300 text-base">neil@nazarethlawfirm.com</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 pt-10">
      <div class="flex flex-col sm:flex-row justify-between items-center gap-4 text-white/50">
        <p class="text-sm">&copy; {new Date().getFullYear()} Nazareth Law Firm. All rights reserved.</p>
        <div class="flex gap-8">
          <a href="/privacy-policy" class="hover:text-primary-400 transition-colors duration-300 text-sm">Privacy Policy</a>
          <a href="/terms-of-service" class="hover:text-primary-400 transition-colors duration-300 text-sm">Terms of Service</a>
        </div>
      </div>
    </div>
  </div>
</footer>
