---
import { CheckCircle2 } from 'lucide-astro';

interface Props {
  formName: string;
}

const { formName } = Astro.props;
---

<form class="flex-1 flex flex-col justify-between" data-netlify="true" name={formName} x-data="{ loading: false, submitted: false, error: false, errorMessage: '' }" @submit.prevent="async (e) => {
  loading = true;
  error = false;
  const formData = new FormData(e.target);
  try {
    const response = await fetch('/', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams(formData).toString()
    });
    if (response.ok) {
      submitted = true;
      e.target.reset();
    } else {
      throw new Error('Submission failed');
    }
  } catch (err) {
    error = true;
    errorMessage = 'Something went wrong. Please try again or call us directly.';
  } finally {
    loading = false;
  }
}">
  <div class="space-y-6">
    <input type="hidden" name="form-name" value={formName} />

    <!-- Success Message -->
    <div x-show="submitted" x-transition class="p-6 bg-green-50 border-2 border-green-500 rounded-none">
      <p class="text-green-800 font-semibold text-center mb-4">Thank you! We'll get back to you within 24 hours.</p>
      <button @click="submitted = false" type="button" class="text-primary-600 font-semibold hover:text-primary-700 transition-colors mx-auto block">
        Submit Another Request
      </button>
    </div>

    <!-- Error Message -->
    <div x-show="error" x-transition class="p-6 bg-red-50 border-2 border-red-500 rounded-none">
      <p class="text-red-800 font-semibold text-center" x-text="errorMessage"></p>
    </div>

    <div x-show="!submitted" x-transition class="space-y-6">
      <div class="grid sm:grid-cols-2 gap-6">
        <div>
          <label for={`${formName}-name`} class="block text-sm font-bold text-gray-700 mb-3 uppercase tracking-wider">Full Name *</label>
          <input
            type="text"
            id={`${formName}-name`}
            name="name"
            required
            class="w-full px-5 py-4 rounded-none border-2 border-gray-300 focus:border-primary-500 focus:ring-0 outline-none transition-all duration-300 text-gray-900 placeholder-gray-400"
            placeholder="John Doe"
          />
        </div>

        <div>
          <label for={`${formName}-phone`} class="block text-sm font-bold text-gray-700 mb-3 uppercase tracking-wider">Phone Number *</label>
          <input
            type="tel"
            id={`${formName}-phone`}
            name="phone"
            required
            class="w-full px-5 py-4 rounded-none border-2 border-gray-300 focus:border-primary-500 focus:ring-0 outline-none transition-all duration-300 text-gray-900 placeholder-gray-400"
            placeholder="(504) 123-4567"
          />
        </div>
      </div>

      <div>
        <label for={`${formName}-email`} class="block text-sm font-bold text-gray-700 mb-3 uppercase tracking-wider">Email Address *</label>
        <input
          type="email"
          id={`${formName}-email`}
          name="email"
          required
          class="w-full px-5 py-4 rounded-none border-2 border-gray-300 focus:border-primary-500 focus:ring-0 outline-none transition-all duration-300 text-gray-900 placeholder-gray-400"
          placeholder="john@example.com"
        />
      </div>

      <div>
        <label for={`${formName}-message`} class="block text-sm font-bold text-gray-700 mb-3 uppercase tracking-wider">Tell Us About Your Case *</label>
        <textarea
          id={`${formName}-message`}
          name="message"
          required
          rows="6"
          class="w-full px-5 py-4 rounded-none border-2 border-gray-300 focus:border-primary-500 focus:ring-0 outline-none transition-all duration-300 resize-none text-gray-900 placeholder-gray-400"
          placeholder="Please provide details about your case, including when it occurred and what type of assistance you need..."
        ></textarea>
      </div>

      <div>
        <button type="submit" :disabled="loading" :class="{ 'opacity-60 cursor-not-allowed': loading }" class="w-full inline-flex items-center justify-center gap-3 px-8 py-4 bg-gradient-to-r from-secondary-300 via-secondary-400 to-secondary-500 gold-shine-button text-white !text-white font-bold uppercase tracking-wider rounded-none shadow-xl shadow-secondary-500/30 hover:shadow-2xl hover:shadow-secondary-500/40 transition-all duration-500 text-lg disabled:hover:translate-y-0 disabled:hover:shadow-xl">
          <span x-show="!loading">Get Your Free Consultation</span>
          <span x-show="loading">Sending...</span>
        </button>
        <p class="text-base text-gray-500 text-center mt-5 flex items-center justify-center gap-2">
          <CheckCircle2 class="w-5 h-5 text-green-600" />
          Your information is confidential and secure
        </p>
      </div>
    </div>
  </div>
</form>
