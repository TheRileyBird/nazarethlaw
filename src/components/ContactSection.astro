---
import CornerAccentCard from './CornerAccentCard.astro';
import ContactForm from './ContactForm.astro';
import { Phone, Mail, MapPin, CheckCircle2 } from 'lucide-astro';

interface Props {
  formName: string;
  title?: string;
  description?: string;
}

const {
  formName,
  title = "Get Your Free Case Evaluation",
  description = "Our experienced team is ready to review your case at no cost. We only get paid when you win."
} = Astro.props;
---

<div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
  <div class="text-center mb-20">
    <div class="inline-block mb-6 slide-in" x-data x-intersect="$el.classList.add('animate')">
      <div class="h-1 w-24 bg-gradient-to-r from-primary-500 via-primary-400 to-transparent mx-auto"></div>
    </div>
    <h2 class="text-gray-900 mb-8 stagger-1" x-data x-intersect="$el.classList.add('animate')">
      {title}
    </h2>
    <p class="text-xl text-gray-600 max-w-2xl mx-auto leading-normal stagger-2" x-data x-intersect="$el.classList.add('animate')">
      {description}
    </p>
  </div>

  <div class="grid lg:grid-cols-5 gap-12 lg:items-stretch">
    <!-- Contact Info Sidebar -->
    <div class="lg:col-span-2 space-y-8 flex flex-col">
      <!-- Quick Contact Cards -->
      <CornerAccentCard accentColor="primary">
        <a href="tel:+15044082284" class="group block bg-white rounded-none p-8 shadow-lg hover:shadow-2xl transition-all duration-500 border border-primary-500/30">
          <div class="flex items-center gap-5">
            <div class="w-16 h-16 bg-primary-50 rounded-none flex items-center justify-center flex-shrink-0 group-hover:bg-primary-100 transition-all duration-500">
              <Phone class="w-7 h-7 text-primary-600" />
            </div>
            <div>
              <div class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Call Now</div>
              <div class="text-2xl font-light text-gray-900 group-hover:text-primary-600 transition-colors tracking-tight">504-408-2284</div>
            </div>
          </div>
        </a>
      </CornerAccentCard>

      <CornerAccentCard accentColor="secondary" class="bg-white rounded-none p-8 shadow-lg border border-secondary-500/30">
        <div class="flex items-center gap-5">
          <div class="w-16 h-16 bg-secondary-50 rounded-none flex items-center justify-center flex-shrink-0">
            <Mail class="w-7 h-7 text-secondary-600" />
          </div>
          <div>
            <div class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Email Us</div>
            <div class="text-lg font-medium text-gray-900">neil@nazarethlawfirm.com</div>
          </div>
        </div>
      </CornerAccentCard>

      <CornerAccentCard accentColor="accent" class="bg-white rounded-none p-8 shadow-lg border border-accent-500/30">
        <div class="flex items-center gap-5">
          <div class="w-16 h-16 bg-accent-50 rounded-none flex items-center justify-center flex-shrink-0">
            <MapPin class="w-7 h-7 text-accent-600" />
          </div>
          <div>
            <div class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Address</div>
            <div class="text-lg font-medium text-gray-900">650 Poydras Street, Suite 2828<br />New Orleans, LA 70130</div>
          </div>
        </div>
      </CornerAccentCard>

      <!-- Trust Indicators -->
      <div class="bg-gradient-to-br from-accent-900 to-accent-700 rounded-none p-10 shadow-2xl border-2 border-accent-600 relative overflow-hidden lg:flex-1">
        <!-- Subtle pattern overlay -->
        <div class="absolute inset-0 bg-pattern-diagonal opacity-10"></div>

        <div class="relative z-10">
          <h4 class="text-xl text-white mb-6 tracking-tight">Why Clients Choose Nazareth Law</h4>
          <ul class="space-y-4">
            <li class="flex items-start gap-4 text-white/90">
              <CheckCircle2 class="w-6 h-6 text-primary-400 flex-shrink-0 mt-1" />
              <span class="text-base leading-normal">No fees unless we win your case</span>
            </li>
            <li class="flex items-start gap-4 text-white/90">
              <CheckCircle2 class="w-6 h-6 text-primary-400 flex-shrink-0 mt-1" />
              <span class="text-base leading-normal">$50M+ secured for individual clients</span>
            </li>
            <li class="flex items-start gap-4 text-white/90">
              <CheckCircle2 class="w-6 h-6 text-primary-400 flex-shrink-0 mt-1" />
              <span class="text-base leading-normal">20+ years of winning experience</span>
            </li>
            <li class="flex items-start gap-4 text-white/90">
              <CheckCircle2 class="w-6 h-6 text-primary-400 flex-shrink-0 mt-1" />
              <span class="text-base leading-normal">Personalized attention to every case</span>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Contact Form -->
    <div class="lg:col-span-3 flex flex-col">
      <div class="bg-white rounded-none shadow-2xl p-10 lg:p-12 border border-gray-200 relative overflow-hidden flex-1 flex flex-col">
        <div class="mb-10">
          <h3 class="text-3xl font-light text-gray-900 mb-3 uppercase tracking-tight">Send Us a Message</h3>
          <p class="text-gray-600 text-lg leading-normal">Fill out the form below and we'll get back to you within 24 hours.</p>
        </div>

        <ContactForm formName={formName} />
      </div>
    </div>
  </div>
</div>
