                <div class="w-16 h-16 bg-primary-50 rounded-none flex items-center justify-center flex-shrink-0 group-hover:bg-primary-100 transition-all duration-500">
                  <Phone class="w-7 h-7 text-primary-600" />
                </div>
                <div>
                  <div class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Call Now</div>
                  <div class="text-2xl font-light text-gray-900 group-hover:text-primary-600 transition-colors tracking-tight">504-408-2284</div>
                </div>
              </div>
            </a>
          </CornerAccentCard>

          <CornerAccentCard accentColor="secondary" class="bg-white rounded-none p-8 shadow-lg border border-secondary-500/30">
            <div class="flex items-center gap-5">
              <div class="w-16 h-16 bg-secondary-50 rounded-none flex items-center justify-center flex-shrink-0">
                <Mail class="w-7 h-7 text-secondary-600" />
              </div>
              <div>
                <div class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Email Us</div>
                <div class="text-lg font-medium text-gray-900">neil@nazarethlawfirm.com</div>
              </div>
            </div>
          </CornerAccentCard>

          <CornerAccentCard accentColor="accent" class="bg-white rounded-none p-8 shadow-lg border border-accent-500/30">
            <div class="flex items-center gap-5">
              <div class="w-16 h-16 bg-accent-50 rounded-none flex items-center justify-center flex-shrink-0">
                <MapPin class="w-7 h-7 text-accent-600" />
              </div>
              <div>
                <div class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Address</div>
                <div class="text-lg font-medium text-gray-900">650 Poydras Street, Suite 2828<br />New Orleans, LA 70130</div>
              </div>
            </div>
          </CornerAccentCard>

          <!-- Trust Indicators -->
          <div class="bg-gradient-to-br from-accent-900 to-accent-700 rounded-none p-10 shadow-2xl border-2 border-accent-600 relative overflow-hidden lg:flex-1">
            <!-- Subtle pattern overlay -->
            <div class="absolute inset-0 bg-pattern-diagonal opacity-10"></div>

            <div class="relative z-10">
              <h4 class="text-xl text-white mb-6 tracking-tight">Why Clients Choose Nazareth Law</h4>
              <ul class="space-y-4">
                <li class="flex items-start gap-4 text-white/90">
                  <CheckCircle2 class="w-6 h-6 text-primary-400 flex-shrink-0 mt-1" />
                  <span class="text-base leading-normal">No fees unless we win your case</span>
                </li>
                <li class="flex items-start gap-4 text-white/90">
                  <CheckCircle2 class="w-6 h-6 text-primary-400 flex-shrink-0 mt-1" />
                  <span class="text-base leading-normal">$50M+ secured for individual clients</span>
                </li>
                <li class="flex items-start gap-4 text-white/90">
                  <CheckCircle2 class="w-6 h-6 text-primary-400 flex-shrink-0 mt-1" />
                  <span class="text-base leading-normal">20+ years of winning experience</span>
                </li>
                <li class="flex items-start gap-4 text-white/90">
                  <CheckCircle2 class="w-6 h-6 text-primary-400 flex-shrink-0 mt-1" />
                  <span class="text-base leading-normal">Personalized attention to every case</span>
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="lg:col-span-3 flex flex-col">
          <div class="bg-white rounded-none shadow-2xl p-10 lg:p-12 border border-gray-200 relative overflow-hidden flex-1 flex flex-col">
            <!-- Subtle corner accents on form -->
            <div class="absolute top-0 left-0 w-20 h-20 border-t-2 border-l-2 border-primary-500/20"></div>
            <div class="absolute bottom-0 right-0 w-20 h-20 border-b-2 border-r-2 border-secondary-500/20"></div>
            <div class="mb-10">
              <h3 class="text-3xl font-light text-gray-900 mb-3 uppercase tracking-tight">Send Us a Message</h3>
              <p class="text-gray-600 text-lg leading-normal">Fill out the form below and we'll get back to you within 24 hours.</p>
            </div>

            <form class="flex-1 flex flex-col justify-between" data-netlify="true" name="homepage-contact" id="homepage-contact-form" x-data="{ loading: false, submitted: false, error: false, errorMessage: '' }" @submit.prevent="async (e) => {
              loading = true;
              error = false;
              const formData = new FormData(e.target);
              try {
                const response = await fetch('/', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                  body: new URLSearchParams(formData).toString()
                });
                if (response.ok) {
                  submitted = true;
                  e.target.reset();
                } else {
                  throw new Error('Submission failed');
                }
              } catch (err) {
                error = true;
                errorMessage = 'Something went wrong. Please try again or call us directly.';
              } finally {
                loading = false;
              }
            }">
              <div class="space-y-6">
                <input type="hidden" name="form-name" value="homepage-contact" />

                <!-- Success Message -->
                <div x-show="submitted" x-transition class="p-6 bg-green-50 border-2 border-green-500 rounded-none">
                  <p class="text-green-800 font-semibold text-center mb-4">Thank you! We'll get back to you within 24 hours.</p>
                  <button @click="submitted = false" type="button" class="text-primary-600 font-semibold hover:text-primary-700 transition-colors mx-auto block">
                    Submit Another Request
                  </button>
                </div>

                <!-- Error Message -->
                <div x-show="error" x-transition class="p-6 bg-red-50 border-2 border-red-500 rounded-none">
                  <p class="text-red-800 font-semibold text-center" x-text="errorMessage"></p>
                </div>

              <div x-show="!submitted" x-transition class="space-y-6">
              <div class="grid sm:grid-cols-2 gap-8">
                <div>
                  <label for="name" class="block text-sm font-bold text-gray-700 mb-3 uppercase tracking-wider">Full Name *</label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="w-full px-5 py-4 rounded-none border-2 border-gray-300 focus:border-primary-500 focus:ring-0 outline-none transition-all duration-300 text-gray-900 placeholder-gray-400"
                    placeholder="John Doe"
                  />
                </div>

                <div>
                  <label for="phone" class="block text-sm font-bold text-gray-700 mb-3 uppercase tracking-wider">Phone Number *</label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    required
                    class="w-full px-5 py-4 rounded-none border-2 border-gray-300 focus:border-primary-500 focus:ring-0 outline-none transition-all duration-300 text-gray-900 placeholder-gray-400"
                    placeholder="(504) 123-4567"
                  />
                </div>
              </div>

              <div>
                <label for="email" class="block text-sm font-bold text-gray-700 mb-3 uppercase tracking-wider">Email Address *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-5 py-4 rounded-none border-2 border-gray-300 focus:border-primary-500 focus:ring-0 outline-none transition-all duration-300 text-gray-900 placeholder-gray-400"
                  placeholder="john@example.com"
                />
              </div>

              <div>
                <label for="message" class="block text-sm font-bold text-gray-700 mb-3 uppercase tracking-wider">Tell Us About Your Case *</label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="6"
                  class="w-full px-5 py-4 rounded-none border-2 border-gray-300 focus:border-primary-500 focus:ring-0 outline-none transition-all duration-300 resize-none text-gray-900 placeholder-gray-400"
                  placeholder="Please provide details about your case, including when it occurred and what type of assistance you need..."
                ></textarea>
              </div>

              <div>
                <button type="submit" :disabled="loading" :class="{ 'opacity-60 cursor-not-allowed': loading }" class="w-full inline-flex items-center justify-center gap-3 px-8 py-4 bg-gradient-to-r from-secondary-300 via-secondary-400 to-secondary-500 gold-shine-button text-white !text-white font-bold uppercase tracking-wider rounded-none shadow-xl shadow-secondary-500/30 hover:shadow-2xl hover:shadow-secondary-500/40 transition-all duration-500 hover:-translate-y-1 text-lg disabled:hover:translate-y-0 disabled:hover:shadow-xl">
                  <span x-show="!loading">Get Your Free Consultation</span>
                  <span x-show="loading">Sending...</span>
                </button>
                <p class="text-base text-gray-500 text-center mt-5 flex items-center justify-center gap-2">
                  <CheckCircle2 class="w-5 h-5 text-green-600" />
                  Your information is confidential and secure
                </p>
              </div>
              </div>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
