  <script is:inline>
    function testimonialCarousel() {
      return {
        activeSlide: 0,
        autoplayInterval: null,
        isTransitioning: false,
        testimonials: [
          {
            quote: "After my mesothelioma diagnosis, I didn't know where to turn. Mr. Nazareth and his team fought tirelessly for my family. They secured a $47 million settlement that will care for us for years to come. Their expertise in asbestos litigation is unmatched.",
            name: "Robert M.",
            case: "Mesothelioma - Shipyard Exposure"
          },
          {
            quote: "Following the refinery explosion, I suffered severe injuries that left me unable to work. The Nazareth Law Firm handled everything with such professionalism and compassion. They recovered $12.5 million for my medical bills and lost wages. I can't thank them enough.",
            name: "Maria S.",
            case: "Industrial Accident - Chemical Plant"
          },
          {
            quote: "When Hurricane Ida destroyed our family business, insurance tried to deny our claim. Mr. Nazareth's team fought back and won us $8.3 million. They turned our worst nightmare into a chance to rebuild stronger than ever.",
            name: "James & Patricia L.",
            case: "Hurricane Property Damage"
          },
          {
            quote: "My husband was killed in an offshore platform accident. During the darkest time of our lives, this firm provided both legal excellence and genuine care. The $23 million settlement they secured ensures our children's future is protected.",
            name: "Jennifer K.",
            case: "Maritime Wrongful Death"
          },
          {
            quote: "The slip and fall at the grocery store left me with permanent back injuries. Mr. Nazareth's team investigated thoroughly and discovered the store's negligence went back months. The $6.8 million verdict gives me financial security for a lifetime of medical care.",
            name: "David T.",
            case: "Premises Liability - Retail Accident"
          },
          {
            quote: "After the industrial explosion at the warehouse, I lost my leg and my ability to provide for my family. This firm fought the corporation's lawyers and won us $15.2 million. They gave us hope when we had none.",
            name: "Carlos R.",
            case: "Catastrophic Workplace Injury"
          },
          {
            quote: "The defective medical device caused me years of pain before we discovered the manufacturer knew about the risks. Mr. Nazareth took on the billion-dollar company and secured a $9.5 million settlement. His dedication to justice is extraordinary.",
            name: "Susan W.",
            case: "Product Liability - Medical Device"
          }
        ],
        init() {
          this.startAutoplay();
        },
        startAutoplay() {
          this.autoplayInterval = setInterval(() => {
            this.next();
          }, 8000);
        },
        stopAutoplay() {
          if (this.autoplayInterval) {
            clearInterval(this.autoplayInterval);
            this.autoplayInterval = null;
          }
        },
        getCurrentTestimonial() {
          return this.testimonials[this.activeSlide];
        },
        next() {
          this.isTransitioning = true;
          setTimeout(() => {
            this.activeSlide = (this.activeSlide + 1) % this.testimonials.length;
            this.isTransitioning = false;
          }, 500);
        },
        prev() {
          this.isTransitioning = true;
          setTimeout(() => {
            this.activeSlide = this.activeSlide === 0 ? this.testimonials.length - 1 : this.activeSlide - 1;
            this.isTransitioning = false;
          }, 500);
        }
      }
    }
  </script>

