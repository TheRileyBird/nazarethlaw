---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { Menu, X, Phone, Mail, MapPin, Scale, Ship, Factory, Users, FileText, Clock, Heart, Home, Package, CloudRain, Building, Briefcase, CheckCircle2 } from '@lucide/astro';
import logo from '../assets/images/logo.png';
import logoHorizontal from '../assets/images/logo-horizontal.png';
import heroBanner from '../assets/images/hero-banner.jpg';
import neilAttorney from '../assets/images/neil-attorney.jpg';
import industrialImage from '../assets/images/industrial-image.jpg';
---

<BaseLayout>
  <!-- Navigation -->
  <nav x-data="{ mobileMenuOpen: false, scrolled: false }" @scroll.window="scrolled = window.scrollY > 50" class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100 transition-all duration-700 ease-in-out" :class="scrolled ? 'shadow-md' : ''">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between transition-all duration-700 ease-in-out" :class="scrolled ? 'h-16' : 'h-20'">
        <!-- Logo -->
        <a href="/" class="flex-shrink-0 transition-all duration-700 ease-in-out">
          <Image src={logoHorizontal} alt="Nazareth Law Firm" class="w-auto transition-all duration-700 ease-in-out" :class="scrolled ? 'h-8' : 'h-12'" />
        </a>

        <!-- Desktop Navigation -->
        <div class="hidden md:flex items-center space-x-8" >
          <a href="#practice-areas" class="text-gray-700 hover:text-primary-600 font-medium transition-colors duration-200 text-sm">Practice Areas</a>
          <a href="#about" class="text-gray-700 hover:text-primary-600 font-medium transition-colors duration-200 text-sm">About</a>
          <a href="#contact" class="text-gray-700 hover:text-primary-600 font-medium transition-colors duration-200 text-sm">Contact</a>
          <a href="tel:+15044082284" class="inline-flex items-center gap-2 bg-accent-500 text-white rounded-lg font-semibold hover:bg-accent-600 transition-all duration-700 ease-in-out shadow-lg shadow-accent-500/20 hover:shadow-xl hover:shadow-accent-500/30" :class="scrolled ? 'px-4 py-2 text-sm' : 'px-6 py-3 text-base'">
            <Phone class="transition-all duration-700 ease-in-out" :class="scrolled ? 'w-3 h-3' : 'w-4 h-4'" />
            504-408-2284
          </a>
        </div>

        <!-- Mobile menu button -->
        <button @click="mobileMenuOpen = !mobileMenuOpen" class="md:hidden p-2 rounded-lg hover:bg-gray-100 transition-colors">
          <Menu x-show="!mobileMenuOpen" class="w-6 h-6 text-gray-700" />
          <X x-show="mobileMenuOpen" x-cloak class="w-6 h-6 text-gray-700" />
        </button>
      </div>

      <!-- Mobile Navigation -->
      <div x-show="mobileMenuOpen" x-cloak class="md:hidden py-4 border-t border-gray-100">
        <div class="flex flex-col space-y-3">
          <a href="#practice-areas" class="text-gray-700 hover:text-primary-600 font-medium px-3 py-2 rounded-lg hover:bg-gray-50 transition-colors">Practice Areas</a>
          <a href="#about" class="text-gray-700 hover:text-primary-600 font-medium px-3 py-2 rounded-lg hover:bg-gray-50 transition-colors">About</a>
          <a href="#contact" class="text-gray-700 hover:text-primary-600 font-medium px-3 py-2 rounded-lg hover:bg-gray-50 transition-colors">Contact</a>
          <a href="tel:+15044082284" class="inline-flex items-center justify-center gap-2 bg-accent-500 text-white px-6 py-3 rounded-lg font-semibold hover:bg-accent-600 transition-colors">
            <Phone class="w-4 h-4" />
            504-408-2284
          </a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20">
    <!-- Background Image with overlay -->
    <div class="absolute inset-0">
      <Image
        src={heroBanner}
        alt="Law office background"
        class="w-full h-full object-cover object-center"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-br from-accent-900/90 via-accent-800/85 to-accent-700/80"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
      <div class="max-w-4xl mx-auto">
        <!-- Accent border decoration -->
        <div class="inline-block mb-6">
          <div class="h-1 w-24 bg-gradient-to-r from-primary-400 to-secondary-400 rounded-full"></div>
        </div>

        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight">
          Representing Victims of Major Industrial Disasters
        </h1>

        <p class="text-xl sm:text-2xl text-gray-200 mb-8 max-w-3xl mx-auto leading-relaxed font-light">
          Expert legal representation for asbestos exposure, maritime incidents, and environmental catastrophes
        </p>

        <!-- Stats -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mb-12 max-w-3xl mx-auto">
          <div class="bg-white/10 backdrop-blur-md rounded-2xl p-6 border border-white/20">
            <div class="text-4xl font-bold text-white mb-2" >$50M+</div>
            <div class="text-sm text-gray-300 font-medium">Single Case Recoveries</div>
          </div>
          <div class="bg-white/10 backdrop-blur-md rounded-2xl p-6 border border-white/20">
            <div class="text-4xl font-bold text-white mb-2" >150+</div>
            <div class="text-sm text-gray-300 font-medium">Cases Won</div>
          </div>
          <div class="bg-white/10 backdrop-blur-md rounded-2xl p-6 border border-white/20">
            <div class="text-4xl font-bold text-white mb-2" >20+</div>
            <div class="text-sm text-gray-300 font-medium">Years of Experience</div>
          </div>
        </div>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="#contact" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-secondary-500 text-white px-8 py-4 rounded-xl font-semibold text-lg hover:bg-secondary-600 transition-all shadow-2xl shadow-secondary-500/30 hover:shadow-secondary-500/50 hover:scale-105">
            <FileText class="w-5 h-5" />
            Free Consultation
          </a>
          <a href="#about" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-white/10 backdrop-blur-md text-white px-8 py-4 rounded-xl font-semibold text-lg hover:bg-white/20 transition-all border border-white/30">
            Learn More
          </a>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <div class="w-6 h-10 border-2 border-white/30 rounded-full flex items-start justify-center p-2">
        <div class="w-1 h-3 bg-white/60 rounded-full"></div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="py-24 bg-gradient-to-b from-white to-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Left: Content -->
        <div>
          <div class="inline-block mb-4">
            <div class="h-1 w-16 bg-gradient-to-r from-primary-500 to-secondary-500 rounded-full"></div>
          </div>

          <h2 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-6" >
            Neil F. Nazareth
          </h2>

          <p class="text-xl text-primary-600 font-semibold mb-6">
            Principal Attorney
          </p>

          <div class="space-y-4 text-lg text-gray-700 leading-relaxed mb-8">
            <p>
              With over two decades of experience, Neil F. Nazareth has dedicated his career to representing victims of major industrial disasters and environmental exposures.
            </p>
            <p>
              Recognized annually as a Louisiana Super Lawyer since 2013, Neil has secured over $50 million in compensation for individual clients in complex asbestos and maritime litigation cases.
            </p>
            <p>
              His expertise spans catastrophic injury claims, wrongful death cases, and holding corporations accountable for negligence that harms workers and communities.
            </p>
          </div>

          <!-- Credentials -->
          <div class="grid sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-xl border-l-4 border-primary-500 shadow-sm">
              <div class="font-semibold text-gray-900 mb-1">Recognition</div>
              <div class="text-sm text-gray-600">Louisiana Super Lawyers 2013-Present</div>
            </div>
            <div class="bg-white p-6 rounded-xl border-l-4 border-secondary-500 shadow-sm">
              <div class="font-semibold text-gray-900 mb-1">Specialization</div>
              <div class="text-sm text-gray-600">Asbestos & Maritime Litigation</div>
            </div>
          </div>
        </div>

        <!-- Right: Professional Image -->
        <div class="relative">
          <div class="aspect-[4/5] rounded-2xl overflow-hidden shadow-2xl">
            <Image
              src={neilAttorney}
              alt="Neil F. Nazareth, Principal Attorney"
              class="w-full h-full object-cover object-center"
            />
          </div>
          <!-- Decorative element -->
          <div class="absolute -bottom-6 -right-6 w-48 h-48 bg-secondary-500/10 rounded-full blur-3xl -z-10"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Practice Areas -->
  <section id="practice-areas" class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <div class="inline-block mb-4">
          <div class="h-1 w-16 bg-gradient-to-r from-primary-500 to-secondary-500 rounded-full mx-auto"></div>
        </div>

        <h2 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-4" >
          Practice Areas
        </h2>

        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          Specialized legal representation for victims of industrial negligence and environmental disasters
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Practice Area Card: Asbestos / Mesothelioma -->
        <a href="/practice-areas/asbestos-mesothelioma" class="group bg-white rounded-2xl p-6 border-2 border-gray-100 hover:border-primary-500 transition-all duration-300 hover:shadow-xl hover:shadow-primary-500/10 hover:-translate-y-1 block">
          <div class="w-12 h-12 bg-gradient-to-br from-primary-500 to-primary-600 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform shadow-lg shadow-primary-500/20">
            <Factory class="w-6 h-6 text-white" />
          </div>

          <h3 class="text-xl font-bold text-gray-900 mb-2" >
            Asbestos / Mesothelioma
          </h3>

          <p class="text-gray-600 text-sm leading-relaxed">
            Representing individuals and families affected by asbestos exposure and mesothelioma, handling workplace injuries and wrongful death claims.
          </p>
        </a>

        <!-- Practice Area Card: Maritime Law -->
        <a href="/practice-areas/maritime" class="group bg-white rounded-2xl p-6 border-2 border-gray-100 hover:border-primary-500 transition-all duration-300 hover:shadow-xl hover:shadow-primary-500/10 hover:-translate-y-1 block">
          <div class="w-12 h-12 bg-gradient-to-br from-primary-500 to-primary-600 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform shadow-lg shadow-primary-500/20">
            <Ship class="w-6 h-6 text-white" />
          </div>

          <h3 class="text-xl font-bold text-gray-900 mb-2" >
            Maritime Law
          </h3>

          <p class="text-gray-600 text-sm leading-relaxed">
            Expert advocacy for offshore workers, seamen, and maritime industry employees injured in vessel accidents and platform incidents.
          </p>
        </a>

        <!-- Practice Area Card: Personal Injury -->
        <a href="/practice-areas/personal-injury" class="group bg-white rounded-2xl p-6 border-2 border-gray-100 hover:border-primary-500 transition-all duration-300 hover:shadow-xl hover:shadow-primary-500/10 hover:-translate-y-1 block">
          <div class="w-12 h-12 bg-gradient-to-br from-secondary-500 to-secondary-600 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform shadow-lg shadow-secondary-500/20">
            <Heart class="w-6 h-6 text-white" />
          </div>

          <h3 class="text-xl font-bold text-gray-900 mb-2" >
            Personal Injury
          </h3>

          <p class="text-gray-600 text-sm leading-relaxed">
            Handling cases involving car crashes, slip-and-falls, medical errors, defective products, and workplace injuries due to negligence.
          </p>
        </a>

        <!-- Practice Area Card: Premises Liability -->
        <a href="/practice-areas/premises-liability" class="group bg-white rounded-2xl p-6 border-2 border-gray-100 hover:border-primary-500 transition-all duration-300 hover:shadow-xl hover:shadow-primary-500/10 hover:-translate-y-1 block">
          <div class="w-12 h-12 bg-gradient-to-br from-accent-500 to-accent-600 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform shadow-lg shadow-accent-500/20">
            <Home class="w-6 h-6 text-white" />
          </div>

          <h3 class="text-xl font-bold text-gray-900 mb-2" >
            Premises Liability
          </h3>

          <p class="text-gray-600 text-sm leading-relaxed">
            Representing clients injured on another's property due to unsafe conditions, including slip-and-falls and negligent security incidents.
          </p>
        </a>

        <!-- Practice Area Card: Product Liability -->
        <a href="/practice-areas/product-liability" class="group bg-white rounded-2xl p-6 border-2 border-gray-100 hover:border-primary-500 transition-all duration-300 hover:shadow-xl hover:shadow-primary-500/10 hover:-translate-y-1 block">
          <div class="w-12 h-12 bg-gradient-to-br from-primary-500 to-primary-600 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform shadow-lg shadow-primary-500/20">
            <Package class="w-6 h-6 text-white" />
          </div>

          <h3 class="text-xl font-bold text-gray-900 mb-2" >
            Product Liability
          </h3>

          <p class="text-gray-600 text-sm leading-relaxed">
            Cases involving defective or dangerous products that cause injuries, pursuing claims for design defects and inadequate warnings.
          </p>
        </a>

        <!-- Practice Area Card: Hurricane Claims -->
        <a href="/practice-areas/hurricane-claims" class="group bg-white rounded-2xl p-6 border-2 border-gray-100 hover:border-primary-500 transition-all duration-300 hover:shadow-xl hover:shadow-primary-500/10 hover:-translate-y-1 block">
          <div class="w-12 h-12 bg-gradient-to-br from-secondary-500 to-secondary-600 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform shadow-lg shadow-secondary-500/20">
            <CloudRain class="w-6 h-6 text-white" />
          </div>

          <h3 class="text-xl font-bold text-gray-900 mb-2" >
            Hurricane Claims
          </h3>

          <p class="text-gray-600 text-sm leading-relaxed">
            Assisting individuals and businesses with hurricane-related insurance claims to maximize recovery for property damage and losses.
          </p>
        </a>

        <!-- Practice Area Card: Property Damage -->
        <a href="/practice-areas/property-damage" class="group bg-white rounded-2xl p-6 border-2 border-gray-100 hover:border-primary-500 transition-all duration-300 hover:shadow-xl hover:shadow-primary-500/10 hover:-translate-y-1 block">
          <div class="w-12 h-12 bg-gradient-to-br from-accent-500 to-accent-600 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform shadow-lg shadow-accent-500/20">
            <Building class="w-6 h-6 text-white" />
          </div>

          <h3 class="text-xl font-bold text-gray-900 mb-2" >
            Property Damage
          </h3>

          <p class="text-gray-600 text-sm leading-relaxed">
            Recovering compensation for damages to homes, vehicles, businesses from accidents, natural disasters, and unforeseen events.
          </p>
        </a>

        <!-- Practice Area Card: Business Interruption -->
        <a href="/practice-areas/business-interruption-claims" class="group bg-white rounded-2xl p-6 border-2 border-gray-100 hover:border-primary-500 transition-all duration-300 hover:shadow-xl hover:shadow-primary-500/10 hover:-translate-y-1 block">
          <div class="w-12 h-12 bg-gradient-to-br from-primary-500 to-primary-600 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform shadow-lg shadow-primary-500/20">
            <Briefcase class="w-6 h-6 text-white" />
          </div>

          <h3 class="text-xl font-bold text-gray-900 mb-2" >
            Business Interruption
          </h3>

          <p class="text-gray-600 text-sm leading-relaxed">
            Helping businesses recover financial losses from operational disruptions caused by disasters, fires, and other covered incidents.
          </p>
        </a>
      </div>
    </div>
  </section>

  <!-- Contact CTA Section -->
  <section id="contact" class="py-32 bg-gray-50 relative overflow-hidden">
    <!-- Decorative elements -->
    <div class="absolute top-0 left-0 w-96 h-96 bg-primary-500/5 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-secondary-500/5 rounded-full blur-3xl translate-x-1/2 translate-y-1/2"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <div class="inline-block mb-4">
          <div class="h-1 w-24 bg-gradient-to-r from-primary-500 to-secondary-500 rounded-full mx-auto"></div>
        </div>
        <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-gray-900 mb-6" >
          Get Your Free Case Evaluation
        </h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">
          Our experienced team is ready to review your case at no cost. We only get paid when you win.
        </p>
      </div>

      <div class="grid lg:grid-cols-5 gap-8 items-start">
        <!-- Contact Info Sidebar -->
        <div class="lg:col-span-2 space-y-6">
          <!-- Quick Contact Cards -->
          <a href="tel:+15044082284" class="group block bg-white rounded-2xl p-6 shadow-sm hover:shadow-md transition-all border-l-4 border-primary-500">
            <div class="flex items-center gap-4">
              <div class="w-14 h-14 bg-primary-50 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
                <Phone class="w-6 h-6 text-primary-600" />
              </div>
              <div>
                <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Call Now</div>
                <div class="text-2xl font-bold text-gray-900 group-hover:text-primary-600 transition-colors">504-408-2284</div>
              </div>
            </div>
          </a>

          <div class="bg-white rounded-2xl p-6 shadow-sm border-l-4 border-secondary-500">
            <div class="flex items-center gap-4 mb-4">
              <div class="w-14 h-14 bg-secondary-50 rounded-xl flex items-center justify-center flex-shrink-0">
                <Mail class="w-6 h-6 text-secondary-600" />
              </div>
              <div>
                <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Email Us</div>
                <div class="text-lg font-semibold text-gray-900">info@nazarethlawfirm.com</div>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-2xl p-6 shadow-sm border-l-4 border-accent-500">
            <div class="flex items-center gap-4">
              <div class="w-14 h-14 bg-accent-50 rounded-xl flex items-center justify-center flex-shrink-0">
                <Clock class="w-6 h-6 text-accent-600" />
              </div>
              <div>
                <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Office Hours</div>
                <div class="text-sm font-medium text-gray-900">Monday - Friday: 9am - 5pm</div>
                <div class="text-xs text-gray-500 mt-1">Weekend consultations available</div>
              </div>
            </div>
          </div>

          <!-- Trust Indicators -->
          <div class="bg-gradient-to-br from-accent-900 to-accent-700 rounded-2xl p-6 shadow-lg">
            <h4 class="text-lg font-bold text-white mb-4" >Why Clients Choose Us</h4>
            <ul class="space-y-3">
              <li class="flex items-start gap-3 text-white/90">
                <CheckCircle2 class="w-5 h-5 text-primary-400 flex-shrink-0 mt-0.5" />
                <span class="text-sm">No fees unless we win your case</span>
              </li>
              <li class="flex items-start gap-3 text-white/90">
                <CheckCircle2 class="w-5 h-5 text-primary-400 flex-shrink-0 mt-0.5" />
                <span class="text-sm">$50M+ secured for individual clients</span>
              </li>
              <li class="flex items-start gap-3 text-white/90">
                <CheckCircle2 class="w-5 h-5 text-primary-400 flex-shrink-0 mt-0.5" />
                <span class="text-sm">20+ years of winning experience</span>
              </li>
              <li class="flex items-start gap-3 text-white/90">
                <CheckCircle2 class="w-5 h-5 text-primary-400 flex-shrink-0 mt-0.5" />
                <span class="text-sm">Personalized attention to every case</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="lg:col-span-3">
          <div class="bg-white rounded-2xl shadow-xl p-8 lg:p-10">
            <div class="mb-8">
              <h3 class="text-2xl font-bold text-gray-900 mb-2" >Send Us a Message</h3>
              <p class="text-gray-600">Fill out the form below and we'll get back to you within 24 hours.</p>
            </div>

            <form class="space-y-6" data-netlify="true" name="contact">
              <input type="hidden" name="form-name" value="contact" />

              <div class="grid sm:grid-cols-2 gap-6">
                <div>
                  <label for="name" class="block text-sm font-semibold text-gray-700 mb-2">Full Name *</label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="w-full px-4 py-3.5 rounded-xl border border-gray-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all text-gray-900 placeholder-gray-400"
                    placeholder="John Doe"
                  />
                </div>

                <div>
                  <label for="phone" class="block text-sm font-semibold text-gray-700 mb-2">Phone Number *</label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    required
                    class="w-full px-4 py-3.5 rounded-xl border border-gray-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all text-gray-900 placeholder-gray-400"
                    placeholder="(504) 123-4567"
                  />
                </div>
              </div>

              <div>
                <label for="email" class="block text-sm font-semibold text-gray-700 mb-2">Email Address *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-3.5 rounded-xl border border-gray-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all text-gray-900 placeholder-gray-400"
                  placeholder="john@example.com"
                />
              </div>

              <div>
                <label for="message" class="block text-sm font-semibold text-gray-700 mb-2">Tell Us About Your Case *</label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="5"
                  class="w-full px-4 py-3.5 rounded-xl border border-gray-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all resize-none text-gray-900 placeholder-gray-400"
                  placeholder="Please provide details about your case, including when it occurred and what type of assistance you need..."
                ></textarea>
              </div>

              <div>
                <button
                  type="submit"
                  class="w-full bg-gradient-to-r from-secondary-500 to-secondary-600 text-white px-8 py-4.5 rounded-xl font-bold text-lg hover:from-secondary-600 hover:to-secondary-700 transition-all shadow-lg shadow-secondary-500/25 hover:shadow-xl hover:shadow-secondary-500/35 hover:-translate-y-0.5"
                >
                  Get Your Free Consultation
                </button>
                <p class="text-sm text-gray-500 text-center mt-4">
                  <CheckCircle2 class="w-4 h-4 inline mr-1 text-green-600" />
                  Your information is confidential and secure
                </p>
              </div>
            </form>
          </div>
