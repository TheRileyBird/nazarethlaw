---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import CornerAccentCard from '../components/CornerAccentCard.astro';
import { Image } from 'astro:assets';
import { Menu, X, Phone, Mail, MapPin, Scale, Ship, Factory, Users, FileText, Clock, Heart, Home, Package, CloudRain, Building, Briefcase, CheckCircle2 } from '@lucide/astro';
import logo from '../assets/images/logo.png';
import logoHorizontal from '../assets/images/logo-horizontal.png';
import heroBanner from '../assets/images/hero-banner.jpg';
import neilAttorney from '../assets/images/neil-attorney.jpg';
import industrialImage from '../assets/images/industrial-image.jpg';
---

<BaseLayout>
  <!-- Navigation -->
  <nav x-data="{ mobileMenuOpen: false, scrolled: false }" @scroll.window="scrolled = window.scrollY > 50" class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100 transition-all duration-700 ease-in-out" :class="scrolled ? 'shadow-md' : ''">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between transition-all duration-700 ease-in-out" :class="scrolled ? 'h-16' : 'h-20'">
        <!-- Logo -->
        <a href="/" class="flex-shrink-0 transition-all duration-700 ease-in-out drop-shadow-md hover:drop-shadow-lg">
          <Image src={logoHorizontal} alt="Nazareth Law Firm" class="w-auto transition-all duration-700 ease-in-out" :class="scrolled ? 'h-8' : 'h-12'" />
        </a>

        <!-- Desktop Navigation -->
        <div class="hidden md:flex items-center space-x-8" >
          <a href="#practice-areas" class="text-gray-700 hover:text-primary-600 font-medium transition-colors duration-200 text-sm">Practice Areas</a>
          <a href="#about" class="text-gray-700 hover:text-primary-600 font-medium transition-colors duration-200 text-sm">About</a>
          <a href="#contact" class="text-gray-700 hover:text-primary-600 font-medium transition-colors duration-200 text-sm">Contact</a>
          <a href="tel:+15044082284" class="inline-flex items-center gap-2 bg-accent-500 text-white rounded-none font-semibold hover:bg-accent-600 transition-all duration-700 ease-in-out shadow-lg shadow-accent-500/20 hover:shadow-xl hover:shadow-accent-500/30 border-2 border-accent-400" :class="scrolled ? 'px-4 py-2 text-sm' : 'px-6 py-3 text-base'">
            <Phone class="transition-all duration-700 ease-in-out" :class="scrolled ? 'w-3 h-3' : 'w-4 h-4'" />
            504-408-2284
          </a>
        </div>

        <!-- Mobile menu button -->
        <button @click="mobileMenuOpen = !mobileMenuOpen" class="md:hidden p-2 rounded-lg hover:bg-gray-100 transition-colors">
          <Menu x-show="!mobileMenuOpen" class="w-6 h-6 text-gray-700" />
          <X x-show="mobileMenuOpen" x-cloak class="w-6 h-6 text-gray-700" />
        </button>
      </div>

      <!-- Mobile Navigation -->
      <div x-show="mobileMenuOpen" x-cloak class="md:hidden py-4 border-t border-gray-100">
        <div class="flex flex-col space-y-3">
          <a href="#practice-areas" class="text-gray-700 hover:text-primary-600 font-medium px-3 py-2 hover:bg-gray-50 transition-colors">Practice Areas</a>
          <a href="#about" class="text-gray-700 hover:text-primary-600 font-medium px-3 py-2 hover:bg-gray-50 transition-colors">About</a>
          <a href="#contact" class="text-gray-700 hover:text-primary-600 font-medium px-3 py-2 hover:bg-gray-50 transition-colors">Contact</a>
          <a href="tel:+15044082284" class="inline-flex items-center justify-center gap-2 bg-accent-500 text-white px-6 py-3 rounded-none font-semibold hover:bg-accent-600 transition-colors border-2 border-accent-400">
            <Phone class="w-4 h-4" />
            504-408-2284
          </a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20">
    <!-- Background Image with proper dark overlay for text contrast -->
    <div class="absolute inset-0">
      <Image
        src={heroBanner}
        alt="Law office background"
        class="w-full h-full object-cover object-center"
        loading="eager"
      />
      <!-- Dark overlay ensuring white text is readable -->
      <div class="absolute inset-0 bg-gradient-to-br from-accent-900/90 via-accent-800/85 to-accent-700/80"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
      <div class="max-w-5xl mx-auto">
        <!-- Accent bar with corner accent -->
        <div class="mb-8 slide-in" x-data x-intersect="$el.classList.add('animate')">
          <div class="h-1 w-24 bg-linear-to-r from-primary-400 via-primary-300 to-transparent"></div>
        </div>

        <h1 class="text-white mb-2 leading-tight max-w-4xl font-bold tracking-widest stagger-1" x-data x-intersect="$el.classList.add('animate')">
          NEIL NAZARETH
        </h1>

        <p class="text-xl sm:text-2xl text-white/90 mb-16 max-w-3xl leading-relaxed stagger-2" x-data x-intersect="$el.classList.add('animate')">
          Help for Victims of Major Industrial Disasters and Environmental Exposures
        </p>

        <!-- Stats with sophisticated corner accents -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mb-16 max-w-3xl mx-auto">
          <CornerAccentCard accentColor="primary" class="bg-white/5 backdrop-blur-md rounded-none p-8 border border-white/30 hover-lift hover:bg-white/10 hover:border-primary-400/50 transition-all duration-500">
            <div class="text-5xl font-light text-white mb-3 tracking-tight">$50M+</div>
            <div class="text-sm text-gray-300 font-medium uppercase tracking-wider">Single Case Recoveries</div>
          </CornerAccentCard>
          <CornerAccentCard accentColor="secondary" class="bg-white/5 backdrop-blur-md rounded-none p-8 border border-white/30 hover-lift hover:bg-white/10 hover:border-secondary-400/50 transition-all duration-500">
            <div class="text-5xl font-light text-white mb-3 tracking-tight">150+</div>
            <div class="text-sm text-gray-300 font-medium uppercase tracking-wider">Cases Won</div>
          </CornerAccentCard>
          <CornerAccentCard accentColor="primary" class="bg-white/5 backdrop-blur-md rounded-none p-8 border border-white/30 hover-lift hover:bg-white/10 hover:border-primary-400/50 transition-all duration-500">
            <div class="text-5xl font-light text-white mb-3 tracking-tight">20+</div>
            <div class="text-sm text-gray-300 font-medium uppercase tracking-wider">Years of Experience</div>
          </CornerAccentCard>
        </div>

        <!-- CTA Buttons -->
        <div class="flex items-center justify-center">
          <Button href="#contact" variant="primary" size="lg" class="w-full sm:w-auto">
            <FileText class="w-5 h-5" />
            Free Consultation
          </Button>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <div class="w-6 h-10 border-2 border-white/30 rounded-full flex items-start justify-center p-2">
        <div class="w-1 h-3 bg-white/60 rounded-full"></div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="py-32 bg-gradient-to-b from-white to-gray-50 relative overflow-hidden bg-pattern-diagonal">
    <!-- Geometric background shapes -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-primary-500/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 border-4 border-secondary-500/5 rotate-45 -translate-x-1/2 translate-y-1/2"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid lg:grid-cols-2 gap-20 items-center">
        <!-- Left: Content -->
        <div>
          <div class="inline-block mb-6 slide-in" x-data x-intersect="$el.classList.add('animate')">
            <div class="h-1 w-24 bg-gradient-to-r from-primary-500 via-primary-400 to-transparent"></div>
          </div>

          <h2 class="text-gray-900 mb-8 stagger-1" x-data x-intersect="$el.classList.add('animate')">
            Neil F. Nazareth
          </h2>

          <p class="text-xl text-primary-600 font-semibold mb-8 tracking-wide uppercase stagger-2" x-data x-intersect="$el.classList.add('animate')">
            Principal Attorney
          </p>

          <div class="space-y-6 text-lg text-gray-700 leading-relaxed mb-10 stagger-3" x-data x-intersect="$el.classList.add('animate')">
            <p>
              With over two decades of experience, Neil F. Nazareth has dedicated his career to representing victims of major industrial disasters and environmental exposures.
            </p>
            <p>
              Recognized annually as a Louisiana Super Lawyer since 2013, Neil has secured over $50 million in compensation for individual clients in complex asbestos and maritime litigation cases.
            </p>
            <p>
              His expertise spans catastrophic injury claims, wrongful death cases, and holding corporations accountable for negligence that harms workers and communities.
            </p>
          </div>

          <!-- Credentials with corner accents -->
          <div class="grid sm:grid-cols-2 gap-6">
            <CornerAccentCard accentColor="primary" class="bg-white p-8 rounded-none border border-primary-500/30 shadow-lg hover-lift hover:border-primary-500 transition-all duration-500">
              <div class="font-bold text-gray-900 mb-2 text-sm uppercase tracking-wider">Recognition</div>
              <div class="text-base text-gray-700 leading-relaxed">Louisiana Super Lawyers 2013-Present</div>
            </CornerAccentCard>
            <CornerAccentCard accentColor="secondary" class="bg-white p-8 rounded-none border border-secondary-500/30 shadow-lg hover-lift hover:border-secondary-500 transition-all duration-500">
              <div class="font-bold text-gray-900 mb-2 text-sm uppercase tracking-wider">Specialization</div>
              <div class="text-base text-gray-700 leading-relaxed">Asbestos & Maritime Litigation</div>
            </CornerAccentCard>
          </div>
        </div>

        <!-- Right: Professional Image -->
        <div class="relative" x-data x-intersect="$el.classList.add('animate')">
          <div class="aspect-[4/5] rounded-none overflow-hidden shadow-2xl border border-gray-200">
            <Image
              src={neilAttorney}
              alt="Neil F. Nazareth, Principal Attorney"
              class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-700"
            />
          </div>
          <!-- Decorative corner accent -->
          <div class="absolute -top-4 -left-4 w-20 h-20 border-t-4 border-l-4 border-primary-500"></div>
          <div class="absolute -bottom-4 -right-4 w-20 h-20 border-b-4 border-r-4 border-secondary-500"></div>
          <!-- Decorative background blur -->
          <div class="absolute -bottom-8 -right-8 w-64 h-64 bg-secondary-500/10 rounded-full blur-3xl -z-10"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Practice Areas -->
  <section id="practice-areas" class="py-32 bg-white relative overflow-hidden bg-pattern-dots">
    <!-- Geometric decorative elements -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-primary-500/5 rounded-full blur-3xl"></div>

    <!-- Geometric triangles -->
    <div class="absolute top-20 right-10 w-24 h-24 border-2 border-primary-500/10 rotate-45"></div>
    <div class="absolute bottom-32 left-16 w-32 h-32 border-2 border-secondary-500/10 rotate-12"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-20">
        <div class="inline-block mb-6 slide-in" x-data x-intersect="$el.classList.add('animate')">
          <div class="h-1 w-24 bg-gradient-to-r from-primary-500 via-primary-400 to-transparent mx-auto"></div>
        </div>

        <h2 class="text-gray-900 mb-6 stagger-1" x-data x-intersect="$el.classList.add('animate')">
          Practice Areas
        </h2>

        <p class="text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed stagger-2" x-data x-intersect="$el.classList.add('animate')">
          Specialized legal representation for victims of industrial negligence and environmental disasters
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Practice Area Card: Asbestos / Mesothelioma -->
        <a href="/practice-areas/asbestos-mesothelioma" class="group bg-white rounded-none p-8 border border-gray-200 hover:border-primary-500 transition-all duration-500 hover:shadow-2xl hover:shadow-primary-500/20 hover:-translate-y-2 block relative overflow-hidden" x-data x-intersect="$el.classList.add('animate')">
          <!-- Hover background reveal -->
          <div class="absolute inset-0 bg-gradient-to-br from-primary-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

          <div class="relative z-10">
            <div class="w-16 h-16 bg-gradient-to-br from-primary-500 to-primary-600 rounded-none flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-500">
              <Factory class="w-8 h-8 text-white" />
            </div>

            <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-primary-600 transition-colors duration-300">
              Asbestos / Mesothelioma
            </h3>

            <p class="text-gray-600 text-base leading-relaxed">
              Representing individuals and families affected by asbestos exposure and mesothelioma, handling workplace injuries and wrongful death claims.
            </p>
          </div>
        </a>

        <!-- Practice Area Card: Maritime Law -->
        <a href="/practice-areas/maritime" class="group bg-white rounded-none p-8 border border-gray-200 hover:border-primary-500 transition-all duration-500 hover:shadow-2xl hover:shadow-primary-500/20 hover:-translate-y-2 block relative overflow-hidden stagger-1" x-data x-intersect="$el.classList.add('animate')">
          <div class="absolute inset-0 bg-gradient-to-br from-primary-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative z-10">
            <div class="w-16 h-16 bg-gradient-to-br from-primary-500 to-primary-600 rounded-none flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-500">
              <Ship class="w-8 h-8 text-white" />
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-primary-600 transition-colors duration-300">
              Maritime Law
            </h3>
            <p class="text-gray-600 text-base leading-relaxed">
              Expert advocacy for offshore workers, seamen, and maritime industry employees injured in vessel accidents and platform incidents.
            </p>
          </div>
        </a>

        <!-- Practice Area Card: Personal Injury -->
        <a href="/practice-areas/personal-injury" class="group bg-white rounded-none p-8 border border-gray-200 hover:border-secondary-500 transition-all duration-500 hover:shadow-2xl hover:shadow-secondary-500/20 hover:-translate-y-2 block relative overflow-hidden stagger-2" x-data x-intersect="$el.classList.add('animate')">
          <div class="absolute inset-0 bg-gradient-to-br from-secondary-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative z-10">
            <div class="gold-shine-card w-16 h-16 bg-gradient-to-br from-secondary-300 to-secondary-500 rounded-none flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-500">
              <Heart class="w-8 h-8 text-white" />
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-secondary-600 transition-colors duration-300">
              Personal Injury
            </h3>
            <p class="text-gray-600 text-base leading-relaxed">
              Handling cases involving car crashes, slip-and-falls, medical errors, defective products, and workplace injuries due to negligence.
            </p>
          </div>
        </a>

        <!-- Practice Area Card: Premises Liability -->
        <a href="/practice-areas/premises-liability" class="group bg-white rounded-none p-8 border border-gray-200 hover:border-accent-500 transition-all duration-500 hover:shadow-2xl hover:shadow-accent-500/20 hover:-translate-y-2 block relative overflow-hidden stagger-3" x-data x-intersect="$el.classList.add('animate')">
          <div class="absolute inset-0 bg-gradient-to-br from-accent-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative z-10">
            <div class="w-16 h-16 bg-gradient-to-br from-accent-500 to-accent-600 rounded-none flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-500">
              <Home class="w-8 h-8 text-white" />
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-accent-600 transition-colors duration-300">
              Premises Liability
            </h3>
            <p class="text-gray-600 text-base leading-relaxed">
              Representing clients injured on another's property due to unsafe conditions, including slip-and-falls and negligent security incidents.
            </p>
          </div>
        </a>

        <!-- Practice Area Card: Product Liability -->
        <a href="/practice-areas/product-liability" class="group bg-white rounded-none p-8 border border-gray-200 hover:border-primary-500 transition-all duration-500 hover:shadow-2xl hover:shadow-primary-500/20 hover:-translate-y-2 block relative overflow-hidden stagger-4" x-data x-intersect="$el.classList.add('animate')">
          <div class="absolute inset-0 bg-gradient-to-br from-primary-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative z-10">
            <div class="w-16 h-16 bg-gradient-to-br from-primary-500 to-primary-600 rounded-none flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-500">
              <Package class="w-8 h-8 text-white" />
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-primary-600 transition-colors duration-300">
              Product Liability
            </h3>
            <p class="text-gray-600 text-base leading-relaxed">
              Cases involving defective or dangerous products that cause injuries, pursuing claims for design defects and inadequate warnings.
            </p>
          </div>
        </a>

        <!-- Practice Area Card: Hurricane Claims -->
        <a href="/practice-areas/hurricane-claims" class="group bg-white rounded-none p-8 border border-gray-200 hover:border-secondary-500 transition-all duration-500 hover:shadow-2xl hover:shadow-secondary-500/20 hover:-translate-y-2 block relative overflow-hidden" x-data x-intersect="$el.classList.add('animate')">
          <div class="absolute inset-0 bg-gradient-to-br from-secondary-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative z-10">
            <div class="gold-shine-card w-16 h-16 bg-gradient-to-br from-secondary-300 to-secondary-500 rounded-none flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-500">
              <CloudRain class="w-8 h-8 text-white" />
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-secondary-600 transition-colors duration-300">
              Hurricane Claims
            </h3>
            <p class="text-gray-600 text-base leading-relaxed">
              Assisting individuals and businesses with hurricane-related insurance claims to maximize recovery for property damage and losses.
            </p>
          </div>
        </a>

        <!-- Practice Area Card: Property Damage -->
        <a href="/practice-areas/property-damage" class="group bg-white rounded-none p-8 border border-gray-200 hover:border-accent-500 transition-all duration-500 hover:shadow-2xl hover:shadow-accent-500/20 hover:-translate-y-2 block relative overflow-hidden stagger-1" x-data x-intersect="$el.classList.add('animate')">
          <div class="absolute inset-0 bg-gradient-to-br from-accent-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative z-10">
            <div class="w-16 h-16 bg-gradient-to-br from-accent-500 to-accent-600 rounded-none flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-500">
              <Building class="w-8 h-8 text-white" />
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-accent-600 transition-colors duration-300">
              Property Damage
            </h3>
            <p class="text-gray-600 text-base leading-relaxed">
              Recovering compensation for damages to homes, vehicles, businesses from accidents, natural disasters, and unforeseen events.
            </p>
          </div>
        </a>

        <!-- Practice Area Card: Business Interruption -->
        <a href="/practice-areas/business-interruption-claims" class="group bg-white rounded-none p-8 border border-gray-200 hover:border-primary-500 transition-all duration-500 hover:shadow-2xl hover:shadow-primary-500/20 hover:-translate-y-2 block relative overflow-hidden stagger-2" x-data x-intersect="$el.classList.add('animate')">
          <div class="absolute inset-0 bg-gradient-to-br from-primary-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative z-10">
            <div class="w-16 h-16 bg-gradient-to-br from-primary-500 to-primary-600 rounded-none flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-500">
              <Briefcase class="w-8 h-8 text-white" />
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-primary-600 transition-colors duration-300">
              Business Interruption
            </h3>
            <p class="text-gray-600 text-base leading-relaxed">
              Helping businesses recover financial losses from operational disruptions caused by disasters, fires, and other covered incidents.
            </p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="py-32 bg-accent-900 relative overflow-hidden">
    <!-- Gradient/Glow Background Effects -->
    <div class="absolute top-0 left-0 w-[800px] h-[800px] bg-primary-500/10 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/3"></div>
    <div class="absolute bottom-0 right-0 w-[600px] h-[600px] bg-blue-500/15 rounded-full blur-3xl translate-x-1/3 translate-y-1/3"></div>
    <div class="absolute top-1/2 left-1/2 w-[500px] h-[500px] bg-secondary-400/5 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center">
        <!-- 5 Gold Stars -->
        <div class="flex justify-center gap-3 mb-6">
          <svg class="w-12 h-12 text-secondary-400 stagger-1" x-data x-intersect="$el.classList.add('animate')" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
          <svg class="w-12 h-12 text-secondary-400 stagger-2" x-data x-intersect="$el.classList.add('animate')" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
          <svg class="w-12 h-12 text-secondary-400 stagger-3" x-data x-intersect="$el.classList.add('animate')" fill="currentColor" viewBox="0 0 20 20">
