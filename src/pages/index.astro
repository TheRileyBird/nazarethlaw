---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import CornerAccentCard from '../components/CornerAccentCard.astro';
import { Image } from 'astro:assets';
import { Phone, Mail, MapPin, Scale, Ship, Factory, Users, FileText, Clock, Heart, Home, Package, CloudRain, Building, Briefcase, CheckCircle2 } from 'lucide-astro';
import heroBanner from '../assets/images/hero-banner.jpg';
import neilAttorney from '../assets/images/neil-attorney.jpg';
import transparentNeil from '../assets/images/transparent-neil.png';
import industrialImage from '../assets/images/industrial-image.jpg';
---

<BaseLayout>
  <Header />

  <!-- Hero Section -->
  <section class="relative flex items-end md:items-center justify-center overflow-hidden pt-20 md:min-h-screen bg-gradient-to-br from-accent-900 via-accent-800 to-accent-700">
    <!-- Large Background Text -->
    <div class="absolute inset-0 flex items-center justify-center overflow-hidden pointer-events-none z-[1] w-full">
      <h1 class="font-extrabold leading-[0.8] text-center select-none w-full"
          style="font-size: clamp(40px, 17.8vw, 362px); background: -webkit-linear-gradient(rgba(245, 245, 245, 1) 40%, rgba(100, 100, 100, .7) 85%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-weight: 800;">
        NAZARETH
      </h1>
    </div>

    <!-- Neil Image -->
    <div class="absolute left-1/2 -translate-x-1/2 z-[5] bottom-0 md:top-28 md:bottom-auto w-full max-w-md md:max-w-xl lg:max-w-2xl h-[55vh] md:h-[65vh] lg:h-[70vh] flex items-end md:items-start justify-center">
      <Image
        src={transparentNeil}
        alt="Neil Nazareth"
        class="w-full h-full object-contain object-bottom md:object-top"
        loading="eager"
      />
    </div>

    <!-- Content -->
    <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 md:flex md:flex-col md:justify-end md:min-h-[calc(100vh-5rem)] pb-8">
      <div class="max-w-5xl mx-auto text-center">

        <!-- Stats with sophisticated corner accents - Desktop Only -->
        <div class="hidden md:grid grid-cols-1 sm:grid-cols-3 gap-8 mb-12 max-w-3xl mx-auto">
          <CornerAccentCard accentColor="primary" class="bg-white/5 backdrop-blur-md rounded-none p-8 border border-white/30 hover-lift hover:bg-white/10 hover:border-primary-400/50 transition-all duration-500">
            <div class="text-5xl font-light text-white mb-3 tracking-tight">$50M+</div>
            <div class="text-sm text-gray-300 font-medium uppercase tracking-wider">Single Case Recoveries</div>
          </CornerAccentCard>
          <CornerAccentCard accentColor="secondary" class="bg-white/5 backdrop-blur-md rounded-none p-8 border border-white/30 hover-lift hover:bg-white/10 hover:border-secondary-400/50 transition-all duration-500">
            <div class="text-5xl font-light text-white mb-3 tracking-tight">150+</div>
            <div class="text-sm text-gray-300 font-medium uppercase tracking-wider">Cases Won</div>
          </CornerAccentCard>
          <CornerAccentCard accentColor="primary" class="bg-white/5 backdrop-blur-md rounded-none p-8 border border-white/30 hover-lift hover:bg-white/10 hover:border-primary-400/50 transition-all duration-500">
            <div class="text-5xl font-light text-white mb-3 tracking-tight">20+</div>
            <div class="text-sm text-gray-300 font-medium uppercase tracking-wider">Years of Experience</div>
          </CornerAccentCard>
        </div>

        <!-- CTA Buttons -->
        <div class="flex items-center justify-center mt-[45vh] md:mt-0 mb-8">
          <Button href="#contact" variant="primary" size="lg" class="w-full sm:w-auto">
            <FileText class="w-5 h-5" />
            Free Consultation
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="py-20 bg-gradient-to-b from-gray-100 to-white relative overflow-hidden bg-pattern-diagonal">
    <!-- Geometric background shapes -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-primary-500/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 border-4 border-secondary-500/5 rotate-45 -translate-x-1/2 translate-y-1/2"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid lg:grid-cols-2 gap-20 items-center">
        <!-- Left: Content -->
        <div>
          <div class="inline-block mb-6 slide-in" x-data x-intersect="$el.classList.add('animate')">
            <div class="h-1 w-24 bg-gradient-to-r from-primary-500 via-primary-400 to-transparent"></div>
          </div>

          <h2 class="text-gray-900 mb-8 stagger-1" x-data x-intersect="$el.classList.add('animate')">
            Neil F. Nazareth
          </h2>

          <p class="text-xl text-primary-600 font-semibold mb-8 tracking-wide uppercase stagger-2" x-data x-intersect="$el.classList.add('animate')">
            Principal Attorney
          </p>

          <div class="space-y-6 text-lg text-gray-700 leading-normal mb-10 stagger-3" x-data x-intersect="$el.classList.add('animate')">
            <p>
              With over two decades of experience, Neil F. Nazareth has dedicated his career to representing victims of major industrial disasters and environmental exposures.
            </p>
            <p>
              Recognized annually as a Louisiana Super Lawyer since 2013, Neil has secured over $50 million in compensation for individual clients in complex asbestos and maritime litigation cases.
            </p>
            <p>
              His expertise spans catastrophic injury claims, wrongful death cases, and holding corporations accountable for negligence that harms workers and communities.
            </p>
          </div>

          <!-- Stats & Credentials with corner accents -->
          <div class="grid sm:grid-cols-2 gap-6">
            <!-- Stats - Mobile Only -->
            <CornerAccentCard accentColor="primary" class="md:hidden bg-white p-8 rounded-none border border-primary-500/30 shadow-lg">
              <div class="text-5xl font-light text-primary-600 mb-3 tracking-tight">$50M+</div>
              <div class="text-sm text-gray-700 font-medium uppercase tracking-wider">Single Case Recoveries</div>
            </CornerAccentCard>
            <CornerAccentCard accentColor="secondary" class="md:hidden bg-white p-8 rounded-none border border-secondary-500/30 shadow-lg">
              <div class="text-5xl font-light text-secondary-600 mb-3 tracking-tight">150+</div>
              <div class="text-sm text-gray-700 font-medium uppercase tracking-wider">Cases Won</div>
            </CornerAccentCard>
            <CornerAccentCard accentColor="accent" class="md:hidden bg-white p-8 rounded-none border border-accent-500/30 shadow-lg">
              <div class="text-5xl font-light text-accent-600 mb-3 tracking-tight">20+</div>
              <div class="text-sm text-gray-700 font-medium uppercase tracking-wider">Years of Experience</div>
            </CornerAccentCard>

            <!-- Credentials -->
            <CornerAccentCard accentColor="primary" class="bg-white p-8 rounded-none border border-primary-500/30 shadow-lg hover-lift hover:border-primary-500 transition-all duration-500">
              <div class="font-bold text-gray-900 mb-2 text-sm uppercase tracking-wider">Recognition</div>
              <div class="text-base text-gray-700 leading-normal">Louisiana Super Lawyers 2013-Present</div>
            </CornerAccentCard>
            <CornerAccentCard accentColor="secondary" class="bg-white p-8 rounded-none border border-secondary-500/30 shadow-lg hover-lift hover:border-secondary-500 transition-all duration-500">
              <div class="font-bold text-gray-900 mb-2 text-sm uppercase tracking-wider">Specialization</div>
              <div class="text-base text-gray-700 leading-normal">Asbestos & Maritime Litigation</div>
            </CornerAccentCard>
          </div>
        </div>

        <!-- Right: Professional Image -->
        <div class="relative" x-data x-intersect="$el.classList.add('animate')">
          <div class="aspect-[4/5] rounded-none overflow-hidden shadow-2xl border border-gray-200">
            <Image
              src={neilAttorney}
              alt="Neil F. Nazareth, Principal Attorney"
              class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-700"
            />
          </div>
          <!-- Decorative corner accent -->
          <div class="absolute -top-4 -left-4 w-20 h-20 border-t-4 border-l-4 border-primary-500"></div>
          <div class="absolute -bottom-4 -right-4 w-20 h-20 border-b-4 border-r-4 border-secondary-500"></div>
          <!-- Decorative background blur -->
          <div class="absolute -bottom-8 -right-8 w-64 h-64 bg-secondary-500/10 rounded-full blur-3xl -z-10"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Practice Areas -->
  <section id="practice-areas" class="py-20 bg-linear-to-b from-white to-gray-500 relative overflow-hidden bg-pattern-dots">
    <!-- Geometric decorative elements -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-primary-500/5 rounded-full blur-3xl"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-20">
        <div class="inline-block mb-6 slide-in" x-data x-intersect="$el.classList.add('animate')">
          <div class="h-1 w-24 bg-gradient-to-r from-primary-500 via-primary-400 to-transparent mx-auto"></div>
        </div>

        <h2 class="text-gray-900 mb-6 stagger-1" x-data x-intersect="$el.classList.add('animate')">
          Practice Areas
        </h2>

        <p class="text-xl text-gray-600 max-w-2xl mx-auto leading-normal stagger-2" x-data x-intersect="$el.classList.add('animate')">
          Specialized legal representation for victims of industrial negligence and environmental disasters
        </p>
      </div>

      <!-- Mobile Accordion -->
      <div class="md:hidden space-y-4" x-data="{ openArea: null }">
        <!-- Asbestos / Mesothelioma -->
        <div class="bg-white rounded-none border border-gray-200 overflow-hidden">
          <button @click="openArea = openArea === 'asbestos' ? null : 'asbestos'" class="w-full p-6 flex items-center justify-between text-left">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-gradient-to-br from-primary-500 to-primary-600 rounded-none flex items-center justify-center flex-shrink-0">
                <Factory class="w-6 h-6 text-white" />
              </div>
              <h3 class="text-lg font-bold text-gray-900">Asbestos / Mesothelioma</h3>
            </div>
            <svg class="w-5 h-5 text-gray-500 transition-transform duration-300" :class="openArea === 'asbestos' ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div x-show="openArea === 'asbestos'"
               x-transition:enter="transition ease-out duration-200"
               x-transition:enter-start="opacity-0 -translate-y-2"
               x-transition:enter-end="opacity-100 translate-y-0"
               x-transition:leave="transition ease-in duration-150"
               x-transition:leave-start="opacity-100 translate-y-0"
               x-transition:leave-end="opacity-0 -translate-y-2"
               class="overflow-hidden">
            <div class="px-6 pb-6">
              <p class="text-gray-600 text-base leading-normal mb-4">
                Representing individuals and families affected by asbestos exposure and mesothelioma, handling workplace injuries and wrongful death claims.
              </p>
              <a href="/practice-areas/asbestos-mesothelioma" class="inline-block text-primary-600 font-semibold hover:text-primary-700 transition-colors">
                Learn More →
              </a>
            </div>
          </div>
        </div>

        <!-- Maritime Law -->
        <div class="bg-white rounded-none border border-gray-200 overflow-hidden">
          <button @click="openArea = openArea === 'maritime' ? null : 'maritime'" class="w-full p-6 flex items-center justify-between text-left">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-gradient-to-br from-secondary-300 to-secondary-500 rounded-none flex items-center justify-center flex-shrink-0">
                <Ship class="w-6 h-6 text-white" />
              </div>
              <h3 class="text-lg font-bold text-gray-900">Maritime Law</h3>
            </div>
            <svg class="w-5 h-5 text-gray-500 transition-transform duration-300" :class="openArea === 'maritime' ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div x-show="openArea === 'maritime'"
               x-transition:enter="transition ease-out duration-200"
               x-transition:enter-start="opacity-0 -translate-y-2"
               x-transition:enter-end="opacity-100 translate-y-0"
               x-transition:leave="transition ease-in duration-150"
               x-transition:leave-start="opacity-100 translate-y-0"
               x-transition:leave-end="opacity-0 -translate-y-2"
               class="overflow-hidden">
            <div class="px-6 pb-6">
              <p class="text-gray-600 text-base leading-normal mb-4">
                Expert advocacy for offshore workers, seamen, and maritime industry employees injured in vessel accidents and platform incidents.
              </p>
              <a href="/practice-areas/maritime" class="inline-block text-secondary-600 font-semibold hover:text-secondary-700 transition-colors">
                Learn More →
              </a>
            </div>
          </div>
        </div>

        <!-- Personal Injury -->
        <div class="bg-white rounded-none border border-gray-200 overflow-hidden">
          <button @click="openArea = openArea === 'personal' ? null : 'personal'" class="w-full p-6 flex items-center justify-between text-left">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-gradient-to-br from-accent-500 to-accent-600 rounded-none flex items-center justify-center flex-shrink-0">
                <Heart class="w-6 h-6 text-white" />
              </div>
              <h3 class="text-lg font-bold text-gray-900">Personal Injury</h3>
            </div>
            <svg class="w-5 h-5 text-gray-500 transition-transform duration-300" :class="openArea === 'personal' ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div x-show="openArea === 'personal'"
               x-transition:enter="transition ease-out duration-200"
               x-transition:enter-start="opacity-0 -translate-y-2"
               x-transition:enter-end="opacity-100 translate-y-0"
               x-transition:leave="transition ease-in duration-150"
               x-transition:leave-start="opacity-100 translate-y-0"
               x-transition:leave-end="opacity-0 -translate-y-2"
               class="overflow-hidden">
            <div class="px-6 pb-6">
              <p class="text-gray-600 text-base leading-normal mb-4">
                Handling cases involving car crashes, slip-and-falls, medical errors, defective products, and workplace injuries due to negligence.
              </p>
              <a href="/practice-areas/personal-injury" class="inline-block text-accent-600 font-semibold hover:text-accent-700 transition-colors">
                Learn More →
              </a>
            </div>
          </div>
        </div>

        <!-- Premises Liability -->
        <div class="bg-white rounded-none border border-gray-200 overflow-hidden">
          <button @click="openArea = openArea === 'premises' ? null : 'premises'" class="w-full p-6 flex items-center justify-between text-left">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-gradient-to-br from-primary-500 to-primary-600 rounded-none flex items-center justify-center flex-shrink-0">
                <Home class="w-6 h-6 text-white" />
              </div>
              <h3 class="text-lg font-bold text-gray-900">Premises Liability</h3>
            </div>
            <svg class="w-5 h-5 text-gray-500 transition-transform duration-300" :class="openArea === 'premises' ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div x-show="openArea === 'premises'"
               x-transition:enter="transition ease-out duration-200"
               x-transition:enter-start="opacity-0 -translate-y-2"
               x-transition:enter-end="opacity-100 translate-y-0"
               x-transition:leave="transition ease-in duration-150"
               x-transition:leave-start="opacity-100 translate-y-0"
               x-transition:leave-end="opacity-0 -translate-y-2"
               class="overflow-hidden">
            <div class="px-6 pb-6">
              <p class="text-gray-600 text-base leading-normal mb-4">
                Representing clients injured on another's property due to unsafe conditions, including slip-and-falls and negligent security incidents.
              </p>
              <a href="/practice-areas/premises-liability" class="inline-block text-primary-600 font-semibold hover:text-primary-700 transition-colors">
                Learn More →
              </a>
            </div>
          </div>
        </div>

        <!-- Product Liability -->
        <div class="bg-white rounded-none border border-gray-200 overflow-hidden">
          <button @click="openArea = openArea === 'product' ? null : 'product'" class="w-full p-6 flex items-center justify-between text-left">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-gradient-to-br from-secondary-300 to-secondary-500 rounded-none flex items-center justify-center flex-shrink-0">
                <Package class="w-6 h-6 text-white" />
              </div>
              <h3 class="text-lg font-bold text-gray-900">Product Liability</h3>
            </div>
            <svg class="w-5 h-5 text-gray-500 transition-transform duration-300" :class="openArea === 'product' ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div x-show="openArea === 'product'"
               x-transition:enter="transition ease-out duration-200"
               x-transition:enter-start="opacity-0 -translate-y-2"
               x-transition:enter-end="opacity-100 translate-y-0"
               x-transition:leave="transition ease-in duration-150"
               x-transition:leave-start="opacity-100 translate-y-0"
               x-transition:leave-end="opacity-0 -translate-y-2"
               class="overflow-hidden">
            <div class="px-6 pb-6">
              <p class="text-gray-600 text-base leading-normal mb-4">
                Cases involving defective or dangerous products that cause injuries, pursuing claims for design defects and inadequate warnings.
              </p>
              <a href="/practice-areas/product-liability" class="inline-block text-secondary-600 font-semibold hover:text-secondary-700 transition-colors">
                Learn More →
              </a>
            </div>
          </div>
        </div>

        <!-- Hurricane Claims -->
        <div class="bg-white rounded-none border border-gray-200 overflow-hidden">
          <button @click="openArea = openArea === 'hurricane' ? null : 'hurricane'" class="w-full p-6 flex items-center justify-between text-left">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-gradient-to-br from-accent-500 to-accent-600 rounded-none flex items-center justify-center flex-shrink-0">
                <CloudRain class="w-6 h-6 text-white" />
              </div>
              <h3 class="text-lg font-bold text-gray-900">Hurricane Claims</h3>
            </div>
            <svg class="w-5 h-5 text-gray-500 transition-transform duration-300" :class="openArea === 'hurricane' ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div x-show="openArea === 'hurricane'"
               x-transition:enter="transition ease-out duration-200"
               x-transition:enter-start="opacity-0 -translate-y-2"
               x-transition:enter-end="opacity-100 translate-y-0"
               x-transition:leave="transition ease-in duration-150"
               x-transition:leave-start="opacity-100 translate-y-0"
               x-transition:leave-end="opacity-0 -translate-y-2"
               class="overflow-hidden">
            <div class="px-6 pb-6">
              <p class="text-gray-600 text-base leading-normal mb-4">
                Assisting individuals and businesses with hurricane-related insurance claims to maximize recovery for property damage and losses.
              </p>
              <a href="/practice-areas/hurricane-claims" class="inline-block text-accent-600 font-semibold hover:text-accent-700 transition-colors">
                Learn More →
              </a>
            </div>
          </div>
        </div>

        <!-- Property Damage -->
        <div class="bg-white rounded-none border border-gray-200 overflow-hidden">
          <button @click="openArea = openArea === 'property' ? null : 'property'" class="w-full p-6 flex items-center justify-between text-left">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-gradient-to-br from-primary-500 to-primary-600 rounded-none flex items-center justify-center flex-shrink-0">
                <Building class="w-6 h-6 text-white" />
              </div>
              <h3 class="text-lg font-bold text-gray-900">Property Damage</h3>
            </div>
            <svg class="w-5 h-5 text-gray-500 transition-transform duration-300" :class="openArea === 'property' ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div x-show="openArea === 'property'"
               x-transition:enter="transition ease-out duration-200"
               x-transition:enter-start="opacity-0 -translate-y-2"
               x-transition:enter-end="opacity-100 translate-y-0"
               x-transition:leave="transition ease-in duration-150"
               x-transition:leave-start="opacity-100 translate-y-0"
               x-transition:leave-end="opacity-0 -translate-y-2"
               class="overflow-hidden">
            <div class="px-6 pb-6">
              <p class="text-gray-600 text-base leading-normal mb-4">
                Recovering compensation for damages to homes, vehicles, businesses from accidents, natural disasters, and unforeseen events.
              </p>
              <a href="/practice-areas/property-damage" class="inline-block text-primary-600 font-semibold hover:text-primary-700 transition-colors">
                Learn More →
              </a>
            </div>
          </div>
        </div>

        <!-- Business Interruption -->
        <div class="bg-white rounded-none border border-gray-200 overflow-hidden">
          <button @click="openArea = openArea === 'business' ? null : 'business'" class="w-full p-6 flex items-center justify-between text-left">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-gradient-to-br from-secondary-300 to-secondary-500 rounded-none flex items-center justify-center flex-shrink-0">
                <Briefcase class="w-6 h-6 text-white" />
              </div>
              <h3 class="text-lg font-bold text-gray-900">Business Interruption</h3>
            </div>
            <svg class="w-5 h-5 text-gray-500 transition-transform duration-300" :class="openArea === 'business' ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div x-show="openArea === 'business'"
               x-transition:enter="transition ease-out duration-200"
               x-transition:enter-start="opacity-0 -translate-y-2"
               x-transition:enter-end="opacity-100 translate-y-0"
               x-transition:leave="transition ease-in duration-150"
               x-transition:leave-start="opacity-100 translate-y-0"
               x-transition:leave-end="opacity-0 -translate-y-2"
               class="overflow-hidden">
            <div class="px-6 pb-6">
              <p class="text-gray-600 text-base leading-normal mb-4">
                Helping businesses recover financial losses from operational disruptions caused by disasters, fires, and other covered incidents.
              </p>
              <a href="/practice-areas/business-interruption-claims" class="inline-block text-secondary-600 font-semibold hover:text-secondary-700 transition-colors">
                Learn More →
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Desktop Grid -->
      <div class="hidden md:grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Practice Area Card: Asbestos / Mesothelioma -->
        <a href="/practice-areas/asbestos-mesothelioma" class="corner-accent corner-accent-primary group bg-white rounded-none p-8 border border-gray-200 hover:border-primary-500 transition-all duration-500 hover:shadow-2xl hover:shadow-primary-500/20 block relative" x-data x-intersect="$el.classList.add('animate')">
          <!-- Hover background reveal -->
