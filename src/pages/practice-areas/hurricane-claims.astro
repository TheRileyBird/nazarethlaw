---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import InteriorHero from '../../components/InteriorHero.astro';
import Button from '../../components/Button.astro';
import { FileText, CheckCircle2, CloudRain } from 'lucide-astro';
import heroBanner from '../../assets/images/hero-banner.jpg';
---

<BaseLayout title="Hurricane Claims - Nazareth Law Firm">
  <Header />

  <InteriorHero
    title="Hurricane Claims"
    description="Maximizing insurance recovery for hurricane damage and losses"
    heroImage={heroBanner}
  />
  <section class="py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none">
        <h2 class="text-3xl font-bold text-gray-900 mb-6" >Hurricane Insurance Claims</h2>

        <p class="text-gray-700 leading-relaxed mb-6">
          Nazareth Law Firm helps individuals and businesses navigate the complex insurance claims process after hurricane damage. We work to maximize your insurance recovery for property damage, business interruption, and other covered losses.
        </p>

        <p class="text-gray-700 leading-relaxed mb-8">
          Insurance companies often delay, deny, or undervalue legitimate claims. Our firm fights to ensure you receive the full compensation you're entitled to under your policy.
        </p>

        <h3 class="text-2xl font-bold text-gray-900 mb-4" >What We Handle</h3>

        <div class="grid md:grid-cols-2 gap-6 mb-8">
          <div class="bg-gray-50 p-6 rounded-xl border-l-4 border-primary-500">
            <CheckCircle2 class="w-6 h-6 text-primary-600 mb-3" />
            <h4 class="font-semibold text-gray-900 mb-2">Property Damage</h4>
            <p class="text-sm text-gray-600">Wind damage, water damage, and structural repairs</p>
          </div>

          <div class="bg-gray-50 p-6 rounded-xl border-l-4 border-primary-500">
            <CheckCircle2 class="w-6 h-6 text-primary-600 mb-3" />
            <h4 class="font-semibold text-gray-900 mb-2">Business Interruption</h4>
            <p class="text-sm text-gray-600">Lost revenue and ongoing expenses during recovery</p>
          </div>

          <div class="bg-gray-50 p-6 rounded-xl border-l-4 border-secondary-500">
            <CheckCircle2 class="w-6 h-6 text-secondary-600 mb-3" />
            <h4 class="font-semibold text-gray-900 mb-2">Denied Claims</h4>
            <p class="text-sm text-gray-600">Challenging wrongful claim denials and bad faith practices</p>
          </div>

          <div class="bg-gray-50 p-6 rounded-xl border-l-4 border-secondary-500">
            <CheckCircle2 class="w-6 h-6 text-secondary-600 mb-3" />
            <h4 class="font-semibold text-gray-900 mb-2">Underpayment</h4>
            <p class="text-sm text-gray-600">Fighting for fair assessment and full compensation</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gradient-to-br from-accent-900 via-accent-800 to-accent-700">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-4" >Don't Accept a Low Settlement</h2>
      <p class="text-xl text-gray-200 mb-8">We'll fight for every dollar you're owed. Contact us today.</p>
      <Button href="/#contact" variant="primary" size="lg">
        <FileText class="w-5 h-5" />
        Request Free Consultation
      </Button>
    </div>
  </section>

  <Footer />
</BaseLayout>
