---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import InteriorHero from '../../components/InteriorHero.astro';
import Button from '../../components/Button.astro';
import { ArrowLeft } from 'lucide-astro';
import courthouseImage from '../../assets/images/site_main.jpg';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Function to get gradient classes - must return complete class strings for Tailwind
function getGradientClasses(from: string, to: string): string {
  const key = `${from}-${to}`;
  const gradients: Record<string, string> = {
    'primary-500-primary-600': 'bg-gradient-to-br from-primary-500 to-primary-600',
    'primary-600-primary-800': 'bg-gradient-to-br from-primary-600 to-primary-800',
    'primary-600-primary-700': 'bg-gradient-to-br from-primary-600 to-primary-700',
    'secondary-300-secondary-600': 'bg-gradient-to-br from-secondary-300 to-secondary-600',
    'accent-500-accent-700': 'bg-gradient-to-br from-accent-500 to-accent-700',
    'accent-600-accent-800': 'bg-gradient-to-br from-accent-600 to-accent-800',
    'accent-600-primary-700': 'bg-gradient-to-br from-accent-600 to-primary-700',
  };
  return gradients[key] || 'bg-gradient-to-br from-primary-600 to-primary-800';
}

const gradientClass = getGradientClasses(entry.data.gradientFrom, entry.data.gradientTo);
---

<style>
  .blog-content :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    line-height: 1.3;
    color: #1f2937;
  }

  .blog-content :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 1rem;
    line-height: 1.4;
    color: #374151;
  }

  .blog-content :global(p) {
    font-size: 1.125rem;
    line-height: 1.8;
    margin-bottom: 1.5rem;
    color: #4b5563;
  }

  .blog-content :global(ul),
  .blog-content :global(ol) {
    font-size: 1.125rem;
    line-height: 1.8;
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    color: #4b5563;
  }

  .blog-content :global(li) {
    margin-bottom: 0.75rem;
  }

  .blog-content :global(strong) {
    font-weight: 600;
    color: #1f2937;
  }

  .blog-content :global(a:not(.inline-flex)) {
    color: #009fb7;
    text-decoration: none;
  }

  .blog-content :global(a:not(.inline-flex):hover) {
    color: #007f92;
    text-decoration: underline;
  }
</style>

<BaseLayout title={`${entry.data.title} - Nazareth Law Firm`}>
  <Header />

  <InteriorHero
    title={entry.data.title}
    description={entry.data.category}
    heroImage={courthouseImage}
  />

  <!-- Blog Post Content -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <article class="bg-white border border-gray-200 rounded-none shadow-xl p-12">
        <!-- Meta Information -->
        <div class="flex items-center gap-2 text-sm text-gray-500 mb-8 pb-8 border-b border-gray-200">
          <span class={`inline-block px-3 py-1 text-sm font-semibold rounded-full ${
            entry.data.category === 'Personal Injury' ? 'bg-primary-50 text-primary-700' :
            entry.data.category === 'Asbestos / Mesothelioma' ? 'bg-secondary-50 text-secondary-700' :
            entry.data.category === 'Product Liability' ? 'bg-accent-50 text-accent-700' :
            'bg-primary-50 text-primary-700'
          }`}>{entry.data.category}</span>
        </div>

        <!-- Settlement Amount Highlight -->
        <div class={`${gradientClass} text-white rounded-none p-12 mb-12 text-center`}>
          <div class="text-7xl font-bold mb-4">{entry.data.settlementAmount}</div>
          <div class="text-2xl font-light">Settlement Amount</div>
        </div>

        <!-- Article Content -->
        <div class="blog-content max-w-none">
          <Content />

          <div class="bg-gray-50 border-l-4 border-primary-500 p-8 my-10">
            <h4 class="text-xl font-bold text-gray-900 mb-4">Need Legal Representation?</h4>
            <p class="text-gray-700 mb-6">
              If you or a loved one has been injured, you may be entitled to significant compensation. The Nazareth Law Firm has the experience and resources to fight for the justice you deserve.
            </p>
            <Button variant="primary" size="lg" href="/contact">
              Schedule Your Free Consultation
            </Button>
          </div>
        </div>

        <!-- Back to Blog -->
        <div class="mt-12 pt-8 border-t border-gray-200">
          <a href="/blog" class="inline-flex items-center gap-2 text-primary-600 hover:text-primary-700 font-semibold">
            <ArrowLeft class="w-5 h-5" />
            Back to Blog
          </a>
        </div>
      </article>
    </div>
  </section>

  <Footer />
</BaseLayout>
