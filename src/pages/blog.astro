---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Clock, ArrowRight } from '@lucide/astro';
---

<BaseLayout title="Blog - Nazareth Law Firm">
  <Header />

  <!-- Hero Section -->
  <section class="pt-32 pb-20 bg-gradient-to-b from-accent-900 to-accent-800 relative overflow-hidden">
    <div class="absolute inset-0 bg-pattern-diagonal opacity-10"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center">
        <h1 class="text-white mb-6">Legal Insights & News</h1>
        <p class="text-xl text-white/90 max-w-3xl mx-auto leading-normal">
          Stay informed with the latest legal news and expert insights
        </p>
      </div>
    </div>
  </section>

  <!-- Blog Posts Section -->
  <section class="py-20 bg-gradient-to-b from-gray-100 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Blog Post 1 -->
        <article class="bg-white border border-gray-200 rounded-none shadow-lg overflow-hidden hover:shadow-2xl transition-shadow duration-300">
          <div class="h-48 bg-gradient-to-br from-primary-500 to-primary-600"></div>
          <div class="p-8">
            <div class="flex items-center gap-2 text-sm text-gray-500 mb-4">
              <Clock class="w-4 h-4" />
              <span>Coming Soon</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Understanding Mesothelioma Claims</h3>
            <p class="text-gray-700 leading-normal mb-4">
              Learn about your rights and options when diagnosed with mesothelioma from asbestos exposure.
            </p>
            <a href="#" class="inline-flex items-center gap-2 text-primary-600 hover:text-primary-700 font-semibold">
              Read More
              <ArrowRight class="w-4 h-4" />
            </a>
          </div>
        </article>

        <!-- Blog Post 2 -->
        <article class="bg-white border border-gray-200 rounded-none shadow-lg overflow-hidden hover:shadow-2xl transition-shadow duration-300">
          <div class="h-48 bg-gradient-to-br from-secondary-300 to-secondary-500"></div>
          <div class="p-8">
            <div class="flex items-center gap-2 text-sm text-gray-500 mb-4">
              <Clock class="w-4 h-4" />
              <span>Coming Soon</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Maritime Law: Know Your Rights</h3>
            <p class="text-gray-700 leading-normal mb-4">
              Essential information for offshore workers and maritime employees about Jones Act claims.
            </p>
            <a href="#" class="inline-flex items-center gap-2 text-primary-600 hover:text-primary-700 font-semibold">
              Read More
              <ArrowRight class="w-4 h-4" />
            </a>
          </div>
        </article>

        <!-- Blog Post 3 -->
        <article class="bg-white border border-gray-200 rounded-none shadow-lg overflow-hidden hover:shadow-2xl transition-shadow duration-300">
          <div class="h-48 bg-gradient-to-br from-accent-500 to-accent-600"></div>
          <div class="p-8">
            <div class="flex items-center gap-2 text-sm text-gray-500 mb-4">
              <Clock class="w-4 h-4" />
              <span>Coming Soon</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Hurricane Damage Claims in Louisiana</h3>
            <p class="text-gray-700 leading-normal mb-4">
              What you need to know about filing insurance claims after hurricane damage to your property.
            </p>
            <a href="#" class="inline-flex items-center gap-2 text-primary-600 hover:text-primary-700 font-semibold">
              Read More
              <ArrowRight class="w-4 h-4" />
            </a>
          </div>
        </article>
      </div>

      <!-- Coming Soon Message -->
      <div class="mt-16 bg-white border border-gray-200 rounded-none shadow-xl p-12 text-center">
        <h2 class="mb-6">Blog Content Coming Soon</h2>
        <p class="text-gray-700 text-lg leading-normal max-w-2xl mx-auto">
          We're currently developing valuable legal content and insights for our clients and the community. Check back soon for updates, or contact us directly with any questions.
        </p>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
