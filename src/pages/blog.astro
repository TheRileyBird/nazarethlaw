---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import InteriorHero from '../components/InteriorHero.astro';
import { Clock, ArrowRight } from '@lucide/astro';

// Get all blog posts and sort by date (newest first)
const allBlogPosts = await getCollection('blog');
const sortedPosts = allBlogPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Function to get excerpt from markdown content (approximately 200 words)
function getExcerpt(content: string, wordLimit: number = 200): string {
  const words = content.split(/\s+/);
  if (words.length <= wordLimit) return content;
  return words.slice(0, wordLimit).join(' ') + '...';
}

// Function to get category badge classes
function getCategoryClasses(category: string) {
  switch(category) {
    case 'Personal Injury':
      return { badge: 'bg-primary-50 text-primary-700', hover: 'hover:text-primary-600', link: 'text-primary-600 hover:text-primary-700' };
    case 'Asbestos / Mesothelioma':
      return { badge: 'bg-secondary-50 text-secondary-700', hover: 'hover:text-secondary-600', link: 'text-secondary-600 hover:text-secondary-700' };
    case 'Product Liability':
    case 'Premises Liability':
      return { badge: 'bg-accent-50 text-accent-700', hover: 'hover:text-accent-600', link: 'text-accent-600 hover:text-accent-700' };
    default:
      return { badge: 'bg-primary-50 text-primary-700', hover: 'hover:text-primary-600', link: 'text-primary-600 hover:text-primary-700' };
  }
}
---

<BaseLayout title="Blog - Nazareth Law Firm">
  <Header />

  <InteriorHero
    title="Legal Insights & News"
    description="Stay informed with the latest legal news and expert insights"
  />

  <!-- Blog Posts Section -->
  <section class="py-20 bg-gradient-to-b from-gray-100 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {sortedPosts.map((post) => {
          const categoryClasses = getCategoryClasses(post.data.category);

          return (
            <article class="bg-white border border-gray-200 rounded-none shadow-lg overflow-hidden hover:shadow-2xl transition-shadow duration-300">
              <a href={`/blog/${post.slug}`} class={`block h-64 bg-gradient-to-br from-${post.data.gradientFrom} to-${post.data.gradientTo} flex items-center justify-center hover:opacity-90 transition-all duration-300`}>
                <div class="text-white text-center px-8">
                  <div class="text-6xl font-bold mb-2">{post.data.settlementDisplay}</div>
                  <div class="text-xl font-light">Settlement</div>
                </div>
              </a>
              <div class="p-8">
                <div class="flex items-center gap-2 text-sm text-gray-500 mb-4">
                  <Clock class="w-4 h-4" />
                  <span>{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                </div>
                <a href={`/blog/${post.slug}`}>
                  <h3 class={`text-2xl font-bold text-gray-900 mb-4 ${categoryClasses.hover} transition-colors`}>{post.data.title}</h3>
                </a>
                <p class="text-gray-700 leading-normal mb-6">
                  {getExcerpt(post.body)}
                </p>
                <div class="flex items-center justify-between border-t border-gray-200 pt-4">
                  <span class={`inline-block px-3 py-1 text-sm font-semibold rounded-full ${categoryClasses.badge}`}>{post.data.category}</span>
                  <a href={`/blog/${post.slug}`} class={`inline-flex items-center gap-2 font-semibold ${categoryClasses.link}`}>
                    Read More
                    <ArrowRight class="w-4 h-4" />
                  </a>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
