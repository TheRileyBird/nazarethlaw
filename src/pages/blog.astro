---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import InteriorHero from '../components/InteriorHero.astro';
import { ArrowRight } from 'lucide-astro';
import courthouseImage from '../assets/images/site_main.jpg';

// Get all blog posts and sort by date (newest first)
const allBlogPosts = await getCollection('blog');
const sortedPosts = allBlogPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Function to get excerpt from markdown content (150 characters, no markdown)
function getExcerpt(content: string, charLimit: number = 150): string {
  // Strip markdown syntax
  let plainText = content
    .replace(/^#{1,6}\s+/gm, '') // Remove headers
    .replace(/\*\*(.+?)\*\*/g, '$1') // Remove bold
    .replace(/\*(.+?)\*/g, '$1') // Remove italic
    .replace(/\[(.+?)\]\(.+?\)/g, '$1') // Remove links
    .replace(/`(.+?)`/g, '$1') // Remove inline code
    .replace(/^[-*+]\s+/gm, '') // Remove list markers
    .replace(/^\d+\.\s+/gm, '') // Remove numbered lists
    .replace(/\n+/g, ' ') // Replace newlines with spaces
    .trim();

  if (plainText.length <= charLimit) return plainText;
  return plainText.slice(0, charLimit).trim() + '...';
}

// Function to get category badge classes
function getCategoryClasses(category: string) {
  switch(category) {
    case 'Personal Injury':
      return { badge: 'bg-primary-50 text-primary-700', hover: 'hover:text-primary-600', link: 'text-primary-600 hover:text-primary-700' };
    case 'Asbestos / Mesothelioma':
      return { badge: 'bg-secondary-50 text-secondary-700', hover: 'hover:text-secondary-600', link: 'text-secondary-600 hover:text-secondary-700' };
    case 'Product Liability':
    case 'Premises Liability':
      return { badge: 'bg-accent-50 text-accent-700', hover: 'hover:text-accent-600', link: 'text-accent-600 hover:text-accent-700' };
    default:
      return { badge: 'bg-primary-50 text-primary-700', hover: 'hover:text-primary-600', link: 'text-primary-600 hover:text-primary-700' };
  }
}

// Function to get gradient classes - must return complete class strings for Tailwind
function getGradientClasses(from: string, to: string): string {
  const key = `${from}-${to}`;
  const gradients: Record<string, string> = {
    'primary-500-primary-600': 'bg-gradient-to-br from-primary-500 to-primary-600',
    'primary-600-primary-800': 'bg-gradient-to-br from-primary-600 to-primary-800',
    'primary-600-primary-700': 'bg-gradient-to-br from-primary-600 to-primary-700',
    'secondary-300-secondary-600': 'bg-gradient-to-br from-secondary-300 to-secondary-600',
    'accent-500-accent-700': 'bg-gradient-to-br from-accent-500 to-accent-700',
    'accent-600-accent-800': 'bg-gradient-to-br from-accent-600 to-accent-800',
    'accent-600-primary-700': 'bg-gradient-to-br from-accent-600 to-primary-700',
  };
  return gradients[key] || 'bg-gradient-to-br from-primary-600 to-primary-800';
}
---

<BaseLayout title="Blog - Nazareth Law Firm">
  <Header />

  <InteriorHero
    title="Legal Insights & News"
    description="Stay informed with the latest legal news and expert insights"
    heroImage={courthouseImage}
  />

  <!-- Blog Posts Section -->
  <section class="py-20 bg-gradient-to-b from-gray-100 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {sortedPosts.map((post, index) => {
          const categoryClasses = getCategoryClasses(post.data.category);
          const patternGradients = [
            'bg-gradient-to-br from-primary-600 to-primary-800',
            'bg-gradient-to-br from-secondary-300 to-secondary-600',
            'bg-gradient-to-br from-accent-500 to-accent-700',
          ];
          const gradientClass = patternGradients[index % 3];
          const label = post.data.category === 'Firm News' ? '' : 'Settlement';

          return (
            <article class="bg-white border border-gray-200 rounded-none shadow-lg overflow-hidden hover:shadow-2xl transition-shadow duration-300">
              <a href={`/blog/${post.id}`} class={`block h-64 ${gradientClass} flex items-center justify-center hover:opacity-90 transition-all duration-300`}>
                <div class="text-white text-center px-8">
                  <div class="text-6xl font-bold mb-2">{post.data.settlementDisplay}</div>
                  {label && <div class="text-xl font-light">{label}</div>}
                </div>
              </a>
              <div class="p-8">
                <a href={`/blog/${post.id}`}>
                  <h3 class={`text-2xl font-bold text-gray-900 mb-4 line-clamp-3 ${categoryClasses.hover} transition-colors`}>{post.data.title}</h3>
                </a>
                <p class="text-gray-700 leading-normal mb-6">
                  {getExcerpt(post.body)}
                </p>
                <div class="flex items-center justify-between border-t border-gray-200 pt-4">
                  <span class={`inline-block px-3 py-1 text-sm font-semibold rounded-full ${categoryClasses.badge}`}>{post.data.category}</span>
                  <a href={`/blog/${post.id}`} class={`inline-flex items-center gap-2 font-semibold ${categoryClasses.link}`}>
                    Read More
                    <ArrowRight class="w-4 h-4" />
                  </a>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
