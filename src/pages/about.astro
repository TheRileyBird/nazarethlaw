---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import InteriorHero from '../components/InteriorHero.astro';
import Button from '../components/Button.astro';
import CornerAccentCard from '../components/CornerAccentCard.astro';
import { Image } from 'astro:assets';
import neilAttorney from '../assets/images/neil-attorney.jpg';
---

<BaseLayout title="About Us - Nazareth Law Firm">
  <Header />

  <InteriorHero
    title="About Neil F. Nazareth"
    description="Over two decades of dedicated legal representation for victims of industrial disasters"
  />

  <!-- About Section -->
  <section class="py-20 bg-gradient-to-b from-gray-100 to-white relative overflow-hidden bg-pattern-diagonal">
    <div class="absolute top-0 right-0 w-96 h-96 bg-primary-500/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 border-4 border-secondary-500/5 rotate-45 -translate-x-1/2 translate-y-1/2"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid lg:grid-cols-2 gap-20 items-center">
        <!-- Left: Content -->
        <div>
          <div class="inline-block mb-6">
            <div class="h-1 w-24 bg-gradient-to-r from-primary-500 via-primary-400 to-transparent"></div>
          </div>

          <h2 class="mb-8">Principal Attorney</h2>

          <div class="space-y-6 text-lg text-gray-700 leading-normal mb-10">
            <p>
              Neil specializes in assisting victims of industrial disasters and environmental exposures. His focus areas include asbestos and maritime litigation, with over 50 million dollars recovered for his clients in single plaintiff cases.
            </p>
            <p>
              Recognized annually as a Louisiana Super Lawyer since 2013, Neil received the Louisiana Super Lawyers Rising Star award in 2013, an honor granted to less than 2.5% of state lawyers.
            </p>
            <p>
              Neil represented the first death case from the Deepwater Horizon explosion and has represented governmental and private landowners for economic losses from the oil spill. He has represented numerous mesothelioma victims and families affected by asbestos exposure.
            </p>
            <p>
              His expertise spans catastrophic injury claims, wrongful death cases, and holding corporations accountable for negligence that harms workers and communities.
            </p>
          </div>

          <!-- Credentials with corner accents -->
          <div class="grid sm:grid-cols-2 gap-6">
            <CornerAccentCard accentColor="primary" class="bg-white p-8 rounded-none border border-primary-500/30 shadow-lg hover-lift hover:border-primary-500 transition-all duration-500">
              <div class="font-bold text-gray-900 mb-2 text-sm uppercase tracking-wider">Recognition</div>
              <div class="text-base text-gray-700 leading-normal">Louisiana Super Lawyers 2013-Present</div>
            </CornerAccentCard>
            <CornerAccentCard accentColor="secondary" class="bg-white p-8 rounded-none border border-secondary-500/30 shadow-lg hover-lift hover:border-secondary-500 transition-all duration-500">
              <div class="font-bold text-gray-900 mb-2 text-sm uppercase tracking-wider">Specialization</div>
              <div class="text-base text-gray-700 leading-normal">Asbestos & Maritime Litigation</div>
            </CornerAccentCard>
          </div>

          <div class="mt-10">
            <Button variant="primary" size="lg" href="/contact">
              Schedule a Free Consultation
            </Button>
          </div>
        </div>

        <!-- Right: Professional Image -->
        <div class="relative">
          <div class="aspect-[4/5] rounded-none overflow-hidden shadow-2xl border border-gray-200">
            <Image
              src={neilAttorney}
              alt="Neil F. Nazareth, Principal Attorney"
              class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-700"
            />
          </div>
          <!-- Decorative corner accent -->
          <div class="absolute -top-4 -left-4 w-20 h-20 border-t-4 border-l-4 border-primary-500"></div>
          <div class="absolute -bottom-4 -right-4 w-20 h-20 border-b-4 border-r-4 border-secondary-500"></div>
          <!-- Decorative background blur -->
          <div class="absolute -bottom-8 -right-8 w-64 h-64 bg-secondary-500/10 rounded-full blur-3xl -z-10"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Education & Leadership Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-16">
        <!-- Education -->
        <div>
          <div class="inline-block mb-6">
            <div class="h-1 w-24 bg-gradient-to-r from-primary-500 via-primary-400 to-transparent"></div>
          </div>
          <h2 class="mb-8">Education</h2>
          <div class="space-y-6">
            <div class="border-l-4 border-primary-500 pl-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">Loyola University of New Orleans School of Law</h3>
              <p class="text-gray-700">Moot Court Board member</p>
              <p class="text-gray-700">Law Excellence Award recipient</p>
            </div>
            <div class="border-l-4 border-secondary-500 pl-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">Louisiana State University</h3>
              <p class="text-gray-700">B.S. Finance, Dean's List</p>
            </div>
          </div>
        </div>

        <!-- Professional Leadership -->
        <div>
          <div class="inline-block mb-6">
            <div class="h-1 w-24 bg-gradient-to-r from-primary-500 via-primary-400 to-transparent"></div>
          </div>
          <h2 class="mb-8">Professional Leadership</h2>
          <ul class="space-y-4 text-gray-700">
            <li class="flex items-start gap-3">
              <div class="w-2 h-2 bg-primary-500 rounded-full mt-2 flex-shrink-0"></div>
              <span>Chair, Admiralty Section, American Association of Justice</span>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-2 h-2 bg-primary-500 rounded-full mt-2 flex-shrink-0"></div>
              <span>Past President, Academy of New Orleans Trial Lawyers</span>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-2 h-2 bg-primary-500 rounded-full mt-2 flex-shrink-0"></div>
              <span>Scoring judge, STAC trial advocacy competition</span>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-2 h-2 bg-primary-500 rounded-full mt-2 flex-shrink-0"></div>
              <span>Loyola University Business Executive Mentor Program mentor</span>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-2 h-2 bg-primary-500 rounded-full mt-2 flex-shrink-0"></div>
              <span>Lobbyist representing asbestos victims at U.S. Senate and House</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Bar Admissions Section -->
  <section class="py-20 bg-gradient-to-b from-gray-50 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <div class="inline-block mb-6">
          <div class="h-1 w-24 bg-gradient-to-r from-primary-500 via-primary-400 to-transparent mx-auto"></div>
        </div>
        <h2 class="mb-6">Bar Admissions</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <div class="bg-white p-8 border-l-4 border-primary-500 shadow-lg">
          <p class="text-gray-700 font-medium">Louisiana State Bar</p>
        </div>
        <div class="bg-white p-8 border-l-4 border-secondary-500 shadow-lg">
          <p class="text-gray-700 font-medium">U.S. District Court (Eastern, Western, and Middle Districts of Louisiana)</p>
        </div>
        <div class="bg-white p-8 border-l-4 border-accent-500 shadow-lg">
          <p class="text-gray-700 font-medium">U.S. Court of Appeals, 5th Circuit</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="mb-6">Why Choose Nazareth Law Firm</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-gradient-to-br from-primary-50 to-white p-8 border-l-4 border-primary-500">
          <h3 class="text-xl font-bold text-gray-900 mb-4">Proven Track Record</h3>
          <p class="text-gray-700 leading-normal">Over $50 million secured for individual clients, with numerous multi-million dollar settlements and verdicts.</p>
        </div>

        <div class="bg-gradient-to-br from-secondary-50 to-white p-8 border-l-4 border-secondary-500">
          <h3 class="text-xl font-bold text-gray-900 mb-4">No Win, No Fee</h3>
          <p class="text-gray-700 leading-normal">We work on a contingency basis, meaning you pay nothing unless we win your case.</p>
        </div>

        <div class="bg-gradient-to-br from-accent-50 to-white p-8 border-l-4 border-accent-500">
          <h3 class="text-xl font-bold text-gray-900 mb-4">Personal Attention</h3>
          <p class="text-gray-700 leading-normal">Every client receives personalized attention and direct access to experienced legal counsel.</p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
