---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import InteriorHero from '../components/InteriorHero.astro';
import Button from '../components/Button.astro';
import ContactSection from '../components/ContactSection.astro';
import { Phone } from 'lucide-astro';
import { Image } from 'astro:assets';
import courthouseImage from '../assets/images/site_main.jpg';
import neilContactImage from '../assets/images/NeilRetouch-3.jpg';
---

<BaseLayout title="Contact Us - Nazareth Law Firm">
  <Header />

  <InteriorHero
    title="Contact Us"
    description="Get in touch with our experienced legal team for a free consultation"
    heroImage={courthouseImage}
  />

  <!-- Professional Attorney Section -->
  <section class="py-20 bg-gradient-to-b from-white to-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Image -->
        <div class="relative">
          <div class="aspect-[4/5] rounded-none overflow-hidden shadow-2xl border border-gray-200">
            <Image
                src={neilContactImage}
                alt="Neil F. Nazareth, Principal Attorney"
                class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-700"
            />
          </div>
          <!-- Decorative corner accents -->
          <div class="absolute -top-4 -left-4 w-20 h-20 border-t-4 border-l-4 border-primary-500"></div>
          <div class="absolute -bottom-4 -right-4 w-20 h-20 border-b-4 border-r-4 border-secondary-500"></div>
        </div>

        <!-- Content -->
        <div>
          <div class="inline-block mb-6">
            <div class="h-1 w-24 bg-gradient-to-r from-primary-500 via-primary-400 to-transparent"></div>
          </div>
          <h2 class="text-gray-900 mb-6">Your Advocate in Times of Need</h2>
          <div class="space-y-4 text-lg text-gray-700 leading-normal">
            <p>
              When you reach out to Nazareth Law Firm, you're not just getting a lawyer—you're getting a dedicated advocate who will fight tirelessly for your rights and your recovery.
            </p>
            <p>
              With over 20 years of experience in complex litigation, Neil F. Nazareth has recovered over $50 million for individual clients and built a reputation for excellence in the legal community.
            </p>
            <p>
              We understand that legal issues can be overwhelming. That's why we offer personalized attention, clear communication, and aggressive representation from start to finish.
            </p>
          </div>
          <div class="mt-8">
            <Button href="tel:+15044082284" variant="primary" size="lg">
              <Phone class="w-5 h-5" />
              Call Now: 504-408-2284
            </Button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-20 bg-gray-50 relative overflow-hidden">
    <ContactSection
      formName="contact"
      title="Let's Discuss Your Case"
      description="Reach out today for a free consultation. We're here to answer your questions and help you understand your legal options."
    />
  </section>

  <Footer />
</BaseLayout>
