---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import { Phone, Mail, MapPin, CheckCircle2 } from '@lucide/astro';
---

<BaseLayout title="Contact Us - Nazareth Law Firm">
  <Header />

  <!-- Hero Section -->
  <section class="pt-32 pb-20 bg-gradient-to-b from-accent-900 to-accent-800 relative overflow-hidden">
    <div class="absolute inset-0 bg-pattern-diagonal opacity-10"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center">
        <h1 class="text-white mb-6">Contact Us</h1>
        <p class="text-xl text-white/90 max-w-3xl mx-auto leading-normal">
          Get in touch with our experienced legal team for a free consultation
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-20 bg-gray-50 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-5 gap-12">
        <!-- Contact Info -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-none shadow-xl p-10 border border-gray-200">
            <h2 class="mb-8">Get In Touch</h2>

            <div class="space-y-8">
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-primary-500 rounded-none flex items-center justify-center flex-shrink-0">
                  <Phone class="w-6 h-6 text-white" />
                </div>
                <div>
                  <h3 class="text-sm font-bold uppercase tracking-wider text-gray-500 mb-2">Phone</h3>
                  <a href="tel:+15044082284" class="text-xl text-gray-900 hover:text-primary-600 transition-colors">504-408-2284</a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-secondary-500 rounded-none flex items-center justify-center flex-shrink-0">
                  <Mail class="w-6 h-6 text-white" />
                </div>
                <div>
                  <h3 class="text-sm font-bold uppercase tracking-wider text-gray-500 mb-2">Email</h3>
                  <a href="mailto:info@nazarethlawfirm.com" class="text-xl text-gray-900 hover:text-primary-600 transition-colors">info@nazarethlawfirm.com</a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-accent-500 rounded-none flex items-center justify-center flex-shrink-0">
                  <MapPin class="w-6 h-6 text-white" />
                </div>
                <div>
                  <h3 class="text-sm font-bold uppercase tracking-wider text-gray-500 mb-2">Office Hours</h3>
                  <p class="text-lg text-gray-900">Monday - Friday: 9:00 AM - 5:00 PM</p>
                  <p class="text-base text-gray-600 mt-2">Available 24/7 for emergencies</p>
                </div>
              </div>
            </div>

            <div class="mt-10 p-6 bg-primary-50 border-l-4 border-primary-500">
              <p class="text-sm font-bold text-primary-900 mb-2 uppercase tracking-wider">Free Consultation</p>
              <p class="text-base text-gray-700 leading-normal">No fees unless we win your case. Contact us today for a free, no-obligation consultation.</p>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="lg:col-span-3">
          <div class="bg-white rounded-none shadow-2xl p-10 lg:p-12 border border-gray-200 relative overflow-hidden">
            <div class="absolute top-0 left-0 w-20 h-20 border-t-2 border-l-2 border-primary-500/20"></div>
            <div class="absolute bottom-0 right-0 w-20 h-20 border-b-2 border-r-2 border-secondary-500/20"></div>
            <div class="mb-10">
              <h2 class="mb-3">Send Us a Message</h2>
              <p class="text-gray-600 text-lg leading-normal">Fill out the form below and we'll get back to you within 24 hours.</p>
            </div>

            <form class="space-y-8" data-netlify="true" name="contact">
              <input type="hidden" name="form-name" value="contact" />

              <div class="grid sm:grid-cols-2 gap-8">
                <div>
                  <label for="name" class="block text-sm font-bold text-gray-700 mb-3 uppercase tracking-wider">Full Name *</label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="w-full px-5 py-4 rounded-none border-2 border-gray-300 focus:border-primary-500 focus:ring-0 outline-none transition-all duration-300 text-gray-900 placeholder-gray-400"
                    placeholder="John Doe"
                  />
                </div>

                <div>
                  <label for="phone" class="block text-sm font-bold text-gray-700 mb-3 uppercase tracking-wider">Phone Number *</label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    required
                    class="w-full px-5 py-4 rounded-none border-2 border-gray-300 focus:border-primary-500 focus:ring-0 outline-none transition-all duration-300 text-gray-900 placeholder-gray-400"
                    placeholder="(504) 123-4567"
                  />
                </div>
              </div>

              <div>
                <label for="email" class="block text-sm font-bold text-gray-700 mb-3 uppercase tracking-wider">Email Address *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-5 py-4 rounded-none border-2 border-gray-300 focus:border-primary-500 focus:ring-0 outline-none transition-all duration-300 text-gray-900 placeholder-gray-400"
                  placeholder="john@example.com"
                />
              </div>

              <div>
                <label for="message" class="block text-sm font-bold text-gray-700 mb-3 uppercase tracking-wider">Tell Us About Your Case *</label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="6"
                  class="w-full px-5 py-4 rounded-none border-2 border-gray-300 focus:border-primary-500 focus:ring-0 outline-none transition-all duration-300 resize-none text-gray-900 placeholder-gray-400"
                  placeholder="Please provide details about your case, including when it occurred and what type of assistance you need..."
                ></textarea>
              </div>

              <div class="relative z-10">
                <Button variant="primary" size="lg" class="w-full">
                  Get Your Free Consultation
                </Button>
                <p class="text-base text-gray-500 text-center mt-5 flex items-center justify-center gap-2">
                  <CheckCircle2 class="w-5 h-5 text-green-600" />
                  Your information is confidential and secure
                </p>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
